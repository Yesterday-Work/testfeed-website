# Example Environment Variables for TestFeed Website
# Copy this file to .env and replace placeholders with actual values.

# Google Analytics 4 Tracking ID (find in GA4 Admin settings)
PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# PostHog Analytics
PUBLIC_POSTHOG_API_KEY="phc_YourPostHogApiKey"
PUBLIC_POSTHOG_API_HOST="https://your-posthog-instance.com"
