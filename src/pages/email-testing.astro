---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Import components used in this landing page
import LandingPageHero from '../components/LandingPageHero.astro';
import ProblemSection from '../components/ProblemSection.astro';
import DemoVideoSection from '../components/DemoVideoSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import UseCasesSection from '../components/UseCasesSection.astro';
import FAQsSection from '../components/FAQsSection.astro';
import FinalCTASection from '../components/FinalCTASection.astro';

// Fetch the content from the landing-pages collection
const landingPageEntries = await getCollection('landing-pages');
const entry = landingPageEntries.find(entry => entry.id === 'email-testing.md');

// Error handling if content file not found
if (!entry) {
  return new Response('Content not found', { status: 404 });
}
---

<BaseLayout title={entry.data.pageTitle} description={entry.data.pageDescription} entry={entry}>
  {/* Only renders components that exist in the content file */}
  {entry.data.landingPageHero && (
    <LandingPageHero {...entry.data.landingPageHero} />
  )}

  {entry.data.problemSection && (
    <ProblemSection {...entry.data.problemSection} />
  )}

  {entry.data.videoSection && (
    <DemoVideoSection {...entry.data.videoSection} />
  )}

  {entry.data.howItWorksSection && (
    <HowItWorksSection {...entry.data.howItWorksSection} />
  )}

  {entry.data.featuresSection && (
    <FeaturesSection {...entry.data.featuresSection} />
  )}

  {entry.data.useCasesSection && (
    <UseCasesSection {...entry.data.useCasesSection} />
  )}

  {entry.data.faqSection && (
    <FAQsSection {...entry.data.faqSection} />
  )}

  {entry.data.finalCtaSection && (
    <FinalCTASection {...entry.data.finalCtaSection} />
  )}
</BaseLayout> 
