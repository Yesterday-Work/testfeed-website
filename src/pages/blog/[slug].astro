---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogHero from "../../components/BlogHero.astro";
import FinalCTASection from "../../components/FinalCTASection.astro";
import MarkdownContent from "../../components/MarkdownContent.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import type { BreadcrumbItem } from "../../components/Breadcrumbs.astro";
import EmpathyMapBuilder from "../../components/tools/empathy-map-builder/EmpathyMapBuilder.astro";

// Get the dynamic route parameter
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");

  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allBlogs: blogEntries },
  }));
}

// Get the entry and all blogs from the params
const { entry, allBlogs } = Astro.props;

// Get related posts based on frontmatter
const relatedPosts = entry.data.relatedPosts
  ? allBlogs.filter((blog) => entry.data.relatedPosts!.includes(blog.slug))
  : [];

// Prepare breadcrumb items
const breadcrumbItems: BreadcrumbItem[] = [
  { label: "home", href: "/" },
  { label: "blog", href: "/blog/" },
  { label: entry.slug },
];

// Extract necessary data for BlogHero
const articleDisplayTitle = entry.data.articleTitle;
const author = entry.data.author || "TestFeed Team";
const publishDate = entry.data.publishDate || new Date();
const featuredImage = entry.data.featuredImage;
const tags = entry.data.tags;

// Render the markdown content
const { Content } = await entry.render();
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  entry={entry}
>
  <BlogHero
    title={articleDisplayTitle}
    author={author}
    publishDate={publishDate}
    featuredImage={featuredImage}
    tags={tags}
  />

  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- Conditional empathy map component for empathy map blog post -->
  {entry.slug === "empathy-map-template" && <EmpathyMapBuilder />}

  <!-- Main content section with the blog content -->
  <section class="blog-content">
    <div class="container">
      <article class="content-wrapper">
        <MarkdownContent>
          <Content />
        </MarkdownContent>
      </article>

      <!-- Related Posts Section -->
      {
        relatedPosts.length > 0 && (
          <div class="related-posts">
            <h2 class="related-posts-title">More blogs you might like</h2>
            <div class="posts-grid">
              {relatedPosts.map((post) => (
                <a href={`/blog/${post.slug}/`} class="post-card">
                  <div class="post-card-content">
                    <h3>{post.data.articleTitle}</h3>
                    <p>{post.data.excerpt}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>

  <!-- Final CTA section if available -->
  {
    entry.data.finalCtaSection && (
      <FinalCTASection {...entry.data.finalCtaSection} />
    )
  }
</BaseLayout>

<style>
  .blog-content {
    padding-top: var(--spacing-sm);
    padding-bottom: var(--spacing-xl);
    padding-left: 0;
    padding-right: 0;
    background-color: var(--color-background);
  }

  .content-wrapper {
    background-color: var(--color-card-bg);
    border-radius: var(--border-radius);
    padding: var(--spacing-md) var(--spacing-xl) var(--spacing-xl);
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: var(--shadow);
  }

  /* Ensure blog headings are left-aligned */
  .content-wrapper :global(h1),
  .content-wrapper :global(h2),
  .content-wrapper :global(h3),
  .content-wrapper :global(h4),
  .content-wrapper :global(h5),
  .content-wrapper :global(h6) {
    text-align: left !important;
  }

  /* Related Posts Section */
  .related-posts {
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-md);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .related-posts-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: var(--spacing-lg);
    color: var(--color-white);
    text-align: center;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-md);
  }

  .post-card {
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: var(--border-radius);
    padding: var(--spacing-md);
    transition: var(--transition);
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background-color: rgba(255, 255, 255, 0.08);
  }

  .post-card-content h3 {
    font-size: 1.1rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-white);
    line-height: 1.3;
  }

  .post-card-content p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0;
    line-height: 1.4;
  }

  /* Responsive adjustments */
  @media (max-width: 992px) {
    .content-wrapper {
      padding: var(--spacing-lg);
    }
  }

  @media (max-width: 768px) {
    .blog-content {
      padding: var(--spacing-lg) 0;
    }

    .content-wrapper {
      padding: var(--spacing-md);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .related-posts-title {
      font-size: 1.3rem;
    }
  }
</style>
