---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogHero from "../../components/BlogHero.astro";
import FinalCTASection from "../../components/FinalCTASection.astro";
import MarkdownContent from "../../components/MarkdownContent.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import type { BreadcrumbItem } from "../../components/Breadcrumbs.astro";
import EmpathyMapBuilder from "../../components/tools/empathy-map-builder/EmpathyMapBuilder.astro";

// Get the dynamic route parameter
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");

  return blogEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, allBlogs: blogEntries },
  }));
}

// Get the entry and all blogs from the params
const { entry, allBlogs } = Astro.props;

// Get related posts based on frontmatter
const relatedPosts = entry.data.relatedPosts
  ? allBlogs.filter((blog) => entry.data.relatedPosts!.includes(blog.slug))
  : [];

// Prepare breadcrumb items
const breadcrumbItems: BreadcrumbItem[] = [
  { label: "home", href: "/" },
  { label: "blog", href: "/blog/" },
  { label: entry.slug },
];

// Extract necessary data for BlogHero
const articleDisplayTitle = entry.data.articleTitle;
const author = entry.data.author || "TestFeed Team";
const publishDate = entry.data.publishDate || new Date();
const featuredImage = entry.data.featuredImage;
const tags = entry.data.tags;

// Render the markdown content
const { Content } = await entry.render();
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  entry={entry}
>
  <BlogHero
    title={articleDisplayTitle}
    author={author}
    publishDate={publishDate}
    featuredImage={featuredImage}
    tags={tags}
  />

  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- Conditional empathy map component for empathy map blog post -->
  {entry.slug === "empathy-map-template" && <EmpathyMapBuilder />}

  <!-- Main content section with the blog content -->
  <section class="blog-content">
    <div class="container">
      <article class="content-wrapper">
        <MarkdownContent>
          <Content />
        </MarkdownContent>
      </article>

      <!-- Related Posts Section -->
      {
        relatedPosts.length > 0 && (
          <div class="related-posts">
            <h2 class="related-posts-title">More blogs you might like</h2>
            <div class="posts-grid">
              {relatedPosts.map((post) => (
                <a href={`/blog/${post.slug}/`} class="post-card">
                  <div class="post-card-content">
                    <h3>{post.data.articleTitle}</h3>
                    <p>{post.data.excerpt}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </section>

  <!-- Final CTA section if available -->
  {
    entry.data.finalCtaSection && (
      <FinalCTASection {...entry.data.finalCtaSection} />
    )
  }
</BaseLayout>

<style>
  .blog-content {
    padding: 48px 0 80px;
    background: var(--bg-1);
  }

  .content-wrapper {
    background: #fff;
    border-radius: 8px;
    padding: 48px 56px 64px;
    max-width: 860px;
    margin: 0 auto;
    border: 1px solid var(--border-1, rgba(0,0,0,0.10));
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }

  /* Related Posts Section */
  .related-posts {
    max-width: 860px;
    margin: 40px auto 0;
  }

  .related-posts-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--tf-ink);
    margin-bottom: 24px;
    letter-spacing: -0.02em;
    text-align: left;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }

  .post-card {
    background: var(--bg-2);
    border-radius: 8px;
    padding: 20px;
    border: 1px solid var(--border-1, rgba(0,0,0,0.10));
    display: block;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    border-color: var(--tf-red);
  }

  .post-card-content h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--tf-ink);
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .post-card-content p {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--tf-stone);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .blog-content { padding: 32px 0 60px; }
    .content-wrapper { padding: 28px 24px 40px; }
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
