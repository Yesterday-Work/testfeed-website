---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostPreview from "../../components/BlogPostPreview.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const posts = allPosts
  .filter((p) => ["Millie Marconi", "Millie"].includes(p.data.author))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const author = {
  name: "Millie Marconi",
  role: "CEO & Co-Founder, TestFeed",
  bio: "Market research practitioner and founder of TestFeed, an AI-native synthetic audience research platform. Writing about audience research, content testing, and decision-making.",
  headshotUrl: "/assets/authors/millie-marconi.jpg",
  linkedinUrl: "https://www.linkedin.com/in/millie-marconi/",
  xUrl: "https://x.com/MillieMarconnni",
};

const title = `${author.name} | TestFeed`;
const description = `Articles by ${author.name}, ${author.role} at TestFeed.`;
---

<BaseLayout title={title} description={description} noHeader>

  <div class="author-page">

    <header class="author-head">
      <div class="head-inner">
        <div class="av-wrap">
          {author.headshotUrl ? (
            <img
              src={author.headshotUrl}
              alt={`${author.name} photo`}
              width="120"
              height="120"
              loading="eager"
              decoding="async"
              class="av"
            />
          ) : (
            <div class="av av-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#B5B5B5" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
              </svg>
            </div>
          )}
        </div>
        <div class="author-meta">
          <p class="eyebrow">Author</p>
          <h1>{author.name}</h1>
          <p class="role">{author.role}</p>
          <p class="bio">{author.bio}</p>
          <div class="socials">
            <a href={author.linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="Millie Marconi on LinkedIn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href={author.xUrl} target="_blank" rel="noopener noreferrer" aria-label="Millie Marconi on X">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.91-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              X / Twitter
            </a>
          </div>
        </div>
      </div>
    </header>

    <div class="posts-wrap">
      <div class="posts-inner">
        <h2 class="section-label">{posts.length} article{posts.length !== 1 ? "s" : ""}</h2>
        <div class="post-grid">
          {posts.map((post) => <BlogPostPreview post={post} />)}
        </div>
      </div>
    </div>

  </div>

</BaseLayout>

<style>
  .author-page {
    background: #F8F5F1;
    min-height: 100vh;
  }

  /* ── Author header ───────────────────────────────────────── */
  .author-head {
    background: #EFEAE3;
    border-bottom: 1px solid rgba(0,0,0,0.10);
  }
  .head-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 60px 40px 52px;
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }
  .av-wrap { flex-shrink: 0; }
  .av {
    width: 120px;
    height: 120px;
    border-radius: 999px;
    object-fit: cover;
    border: 3px solid rgba(0,0,0,0.08);
    display: block;
  }
  .av-placeholder {
    background: #E8E1DA;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .author-meta { flex: 1; min-width: 0; }
  .eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #E6392E;
    margin: 0 0 10px;
  }
  .author-head h1 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #111111;
    margin: 0 0 8px;
  }
  .role {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #E6392E;
    margin: 0 0 14px;
  }
  .bio {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #5F5F5F;
    margin: 0 0 20px;
    max-width: 600px;
  }
  .socials {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .socials a {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #111;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.25);
    padding-bottom: 1px;
  }
  .socials a:hover { color: #E6392E; border-color: #E6392E; }

  /* ── Posts section ───────────────────────────────────────── */
  .posts-wrap {
    padding: 52px 0 80px;
  }
  .posts-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .section-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #5F5F5F;
    margin: 0 0 28px;
  }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 700px) {
    .head-inner {
      flex-direction: column;
      gap: 24px;
      padding: 40px 20px 36px;
    }
    .av { width: 88px; height: 88px; }
    .posts-inner { padding: 0 20px; }
    .post-grid { grid-template-columns: 1fr; }
    .posts-wrap { padding: 36px 0 60px; }
  }
</style>
