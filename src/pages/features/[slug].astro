---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FinalCTASection from '../../components/FinalCTASection.astro';

// Get homepage content for CTA section and video
const homepageEntries = await getCollection('homepage');
const homepageEntry = homepageEntries.find(entry => entry.id === 'main.md') || homepageEntries[0];
const videoId = homepageEntry.data.videoSection?.videoId || "Ic-OcghxCuk";

// Get all feature entries for static paths and "other features" section
export async function getStaticPaths() {
  const featureEntries = await getCollection('features');
  return featureEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, allFeatures: featureEntries },
  }));
}

// Get the feature entry and all features from props
const { entry, allFeatures } = Astro.props;
const otherFeatures = allFeatures.filter(feature => feature.slug !== entry.slug);
const { Content } = await entry.render();
---

<BaseLayout 
  title={`${entry.data.title} - TestFeed`}
  description={entry.data.description}
>
  <div class="py-12 lg:py-20">
    <div class="container mx-auto px-4">
      <div class="mb-8 flex items-center">
        <a href="/features" class="text-primary hover:underline flex items-center">
          <span class="back-icon-wrapper">
            <svg xmlns="http://www.w3.org/2000/svg" class="feature-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
          </span>
          All Features
        </a>
      </div>

      <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; margin: 0 auto 3rem auto; max-width: 800px; padding: 0 1rem;">
        {entry.data.icon && (
          <div style="display: flex; justify-content: center; align-items: center; margin-bottom: 1.5rem; color: var(--color-primary);">
            <svg xmlns="http://www.w3.org/2000/svg" style="width: 48px; height: 48px; min-width: 48px; min-height: 48px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {entry.data.icon === 'download' && <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>}
              {entry.data.icon === 'type' && <path d="M4 7V4h16v3M9 20h6M12 4v16"/>}
              {/* Add more icon paths as needed */}
            </svg>
          </div>
        )}
        <h1 style="font-size: 2.5rem; line-height: 1.2; font-weight: 700; margin-bottom: 1.5rem; text-align: center; width: 100%;">{entry.data.title}</h1>
        <p style="font-size: 1.25rem; color: var(--color-gray-400, #a0aec0); margin: 0 auto 2rem auto; text-align: center; width: 100%; max-width: 48rem;">{entry.data.description}</p>
        <div style="margin-bottom: 3rem; text-align: center;">
          <a href="/signup" style="display: inline-block; background-color: var(--color-primary); color: var(--color-secondary); font-weight: 700; padding: 0.75rem 2rem; border-radius: var(--border-radius); transition: all 0.3s ease; text-decoration: none;" class="btn btn-primary pulse">
            Sign Up Free
          </a>
          <p style="margin-top: 0.75rem; font-size: 0.875rem; color: var(--color-gray-400);">Trusted by 10,000+ people worldwide</p>
        </div>
      </div>

      <!-- Video Section -->
      <div class="video-container mb-32">
        <div class="video-placeholder" role="button" tabindex="0" aria-label="Play video">
          <img src={`https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`} alt="Video thumbnail" loading="lazy" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; border-radius: var(--border-radius-lg);"/>
          <div class="play-button">
            <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M8 5V19L19 12L8 5Z"/></svg>
          </div>
        </div>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-xl shadow-lg overflow-hidden p-6 p-8 md:p-10 mb-20">
          <div class="prose prose-lg max-w-none content-section">
            <Content />
          </div>
        </div>

        <!-- Other Features Section -->
        {otherFeatures.length > 0 && (
          <div class="other-features mb-16">
            <h2 class="text-3xl font-bold mb-8 text-center">Explore Other Features</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {otherFeatures.map((feature) => (
                <a href={`/features/${feature.slug}`} class="feature-card">
                  <div class="flex items-center">
                    {feature.data.icon && (
                      <div class="feature-card-icon-container mr-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="feature-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          {feature.data.icon === 'download' && <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>}
                          {feature.data.icon === 'type' && <path d="M4 7V4h16v3M9 20h6M12 4v16"/>}
                        </svg>
                      </div>
                    )}
                    <div>
                      <h3 class="text-xl font-bold">{feature.data.title}</h3>
                      <p class="text-gray-400 line-clamp-2">{feature.data.description}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  {homepageEntry.data.finalCtaSection && (
    <FinalCTASection {...homepageEntry.data.finalCtaSection} />
  )}
</BaseLayout>

<style>
  .back-icon-wrapper {
    display: inline-flex;
    align-items: center;
    margin-right: 4px;
  }
  
  .feature-nav-icon {
    width: 16px !important;
    height: 16px !important;
    max-width: 16px !important;
    max-height: 16px !important;
  }
  
  /* Feature header styling */
  .feature-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    max-width: 4xl;
    margin: 0 auto 3rem auto;
    padding: 0 1rem;
  }
  
  .feature-header-icon-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1.5rem;
    color: var(--color-primary);
  }
  
  .feature-header-icon {
    width: 48px !important;
    height: 48px !important;
    max-width: 48px !important;
    max-height: 48px !important;
    min-width: 48px !important;
    min-height: 48px !important;
  }

  .feature-title {
    font-size: 2.5rem;
    line-height: 1.2;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-align: center;
    width: 100%;
  }

  @media (min-width: 768px) {
    .feature-title {
      font-size: 3rem;
    }
  }

  .feature-description {
    font-size: 1.25rem;
    color: var(--color-gray-400, #a0aec0);
    max-width: 48rem;
    margin: 0 auto 2rem auto;
    text-align: center;
    width: 100%;
  }

  .feature-cta {
    margin-bottom: 3rem;
    text-align: center;
  }

  .signup-button {
    display: inline-block;
    background-color: var(--color-primary);
    color: white;
    font-weight: 700;
    padding: 0.75rem 2rem;
    border-radius: 9999px;
    transition: all 0.3s ease;
    transform: translateY(0);
  }

  .signup-button:hover {
    background-color: var(--color-primary-dark, var(--color-primary));
    transform: scale(1.05);
  }
  
  .feature-icon-container {
    display: inline-flex;
    align-items: center;
  }

  /* Hide the first h1 in the content */
  .content-without-h1 :global(h1:first-child) {
    display: none;
  }
  
  /* Content section styles */
  .content-section {
    color: var(--color-text, #333);
  }
  
  .content-section :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  
  .content-section :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  
  .content-section :global(h4) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  
  .content-section :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }
  
  .content-section :global(h2 + p),
  .content-section :global(h3 + p),
  .content-section :global(h4 + p) {
    margin-top: 0.5rem;
  }
  
  .content-section :global(ul),
  .content-section :global(ol) {
    margin: 1.5rem 0 2rem;
    padding-left: 1.75rem;
  }
  
  .content-section :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.6;
    position: relative;
    padding-left: 0.5rem;
  }
  
  .content-section :global(ul li::before) {
    content: '';
    position: absolute;
    left: -1rem;
    top: 0.7rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-primary);
  }
  
  .content-section :global(ol li) {
    padding-left: 0.25rem;
  }
  
  .content-section :global(pre) {
    margin: 1.5rem 0 2rem;
    padding: 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
  }
  
  .content-section :global(blockquote) {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid var(--color-primary);
    background-color: rgba(0, 0, 0, 0.03);
    font-style: italic;
  }
  
  @media (min-width: 768px) {
    .content-section :global(ul),
    .content-section :global(ol) {
      padding-left: 2.5rem;
    }
    
    .content-section :global(li) {
      padding-left: 0.75rem;
    }
  }

  /* Video section styles */
  .video-container {
    position: relative;
    width: 100%;
    max-width: 1000px;
    margin: 3rem auto 6rem;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transition: var(--transition);
    padding: 0 1rem;
  }

  @media (min-width: 768px) {
    .video-container {
      margin: 4rem auto 8rem;
      padding: 0 2rem;
    }
  }

  .video-container:hover {
    transform: scale(1.01);
    box-shadow: var(--shadow-lg), var(--glow);
  }

  .video-placeholder {
    background-color: rgba(0, 0, 0, 0.8);
    border-radius: var(--border-radius-lg);
    aspect-ratio: 16 / 9;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
  }

  .video-placeholder::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 1;
  }

  .video-placeholder .play-button {
    position: relative;
    z-index: 2;
  }

  .video-placeholder:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-lg), var(--glow);
  }

  .play-button {
    background-color: var(--color-primary);
    color: var(--color-secondary);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1.5rem;
    box-shadow: var(--glow);
  }

  .play-icon {
    width: 30px;
    height: 30px;
    color: var(--color-secondary);
  }

  /* Other features section styles */
  .feature-card {
    background-color: var(--color-card-bg, #222);
    padding: 1.5rem;
    border-radius: var(--border-radius, 10px);
    transition: var(--transition, all 0.3s ease);
    border: 1px solid rgba(255, 255, 255, 0.05);
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg, 0 10px 15px rgba(0, 0, 0, 0.5));
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .feature-card-icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-highlight, #fff);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script define:vars={{ videoId }}>
  document.addEventListener('DOMContentLoaded', () => {
    const videoContainer = document.querySelector('.video-container');
    if (!videoContainer) return;

    const placeholder = videoContainer.querySelector('.video-placeholder');
    if (!placeholder) return;

    placeholder.addEventListener('click', loadVideo);
    placeholder.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        loadVideo();
      }
    });

    function loadVideo() {
      placeholder.removeEventListener('click', loadVideo);
      placeholder.removeEventListener('keydown', loadVideo);
      
      const iframe = document.createElement('iframe');
      iframe.setAttribute('width', '100%');
      iframe.setAttribute('height', '500');
      iframe.setAttribute('src', `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`);
      iframe.setAttribute('title', 'TestFeed Demo Video');
      iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
      iframe.setAttribute('allowfullscreen', '');
      iframe.style.borderRadius = 'var(--border-radius-lg)';
      iframe.style.display = 'block';

      videoContainer.innerHTML = '';
      videoContainer.appendChild(iframe);
    }
  });
</script> 