---
// TestFeed landing page — ported from the Claude Design handoff bundle
// ("Landing Page.html"). Self-contained editorial design with its own
// header/footer/nav, so it intentionally does NOT use BaseLayout.
const title = "TestFeed — Customer feedback on-demand.";
const description =
  "AI respondents built from real audience data. We build an AI panel of your audience, so you can ask them anything, at any time — a score, the quotes, and the next move in under an hour.";
const bookingUrl = "https://app.usemotion.com/meet/millie-marconi/meeting";
const siteUrl = Astro.url.origin;
const ogImage = new URL("/assets/og-image.jpg", siteUrl).href;
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  description,
  url: Astro.url.href,
  image: ogImage,
};
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={Astro.url.href} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={Astro.url.href} />
<meta property="og:image" content={ogImage} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="TestFeed" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:site" content="@testfeed" />
<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="/assets/ds.css" />
<script src="https://unpkg.com/lucide@0.456.0/dist/umd/lucide.min.js" is:inline></script>
<style>
  :root {
    --page: #F8F5F1;
    --band: #EFEAE3;
    --card: #F1EDE7;
    --line: rgba(0,0,0,0.10);
    --dash: #161616;
    --dash-card: #1D1D1D;
    --dash-line: rgba(255,255,255,0.10);
    --wrap: 1200px;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  html, body { margin: 0; background: var(--page); overflow-x: hidden; }
  body { font-family: var(--font-body); color: var(--tf-ink); -webkit-font-smoothing: antialiased; }
  img { display: block; max-width: 100%; }
  .wrap { max-width: var(--wrap); margin: 0 auto; padding: 0 40px; }

  /* ---- shared ---- */
  .eyebrow-red {
    color: var(--tf-red);
    font-family: var(--font-body);
    font-weight: var(--w-bold);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }
  .display { font-family: var(--font-display); font-weight: 700; letter-spacing: -0.02em; line-height: 1.0; color: var(--tf-black); }
  .dot-red { color: var(--tf-red); }

  /* ============ HEADER ============ */
  .site-header { padding: 26px 0 18px; position: relative; }
  .site-header .wrap { display: flex; align-items: center; gap: 28px; }
  .wordmark {
    display: inline-flex; align-items: flex-end; gap: 0;
    line-height: 1; text-decoration: none; border: 0;
  }
  .wordmark img { height: 22px; width: auto; display: block; }
  .logodot { width: 5px; height: 5px; border-radius: 999px; background: var(--tf-red); display: inline-block; margin: 0 0 3px 3px; flex: 0 0 auto; }
  .nav {
    display: flex; gap: 34px; align-items: center;
    margin: 0 auto;
  }
  .nav a:not(.btn) {
    color: var(--tf-ink);
    font-family: var(--font-body);
    font-weight: var(--w-medium);
    font-size: 15px;
    text-decoration: none;
    border: 0;
    cursor: pointer;
    white-space: nowrap;
  }
  .nav a:not(.btn):hover { color: var(--tf-red); }
  .nav a.nav-cta { display: none; }
  .nav-toggle {
    display: none;
    background: none; border: 0; cursor: pointer;
    color: var(--tf-black); padding: 6px; margin-left: auto;
    align-items: center; justify-content: center;
  }
  .nav-toggle svg { width: 26px; height: 26px; }

  .btn {
    display: inline-flex; align-items: center; gap: 16px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 16px;
    padding: 11px 12px 11px 22px;
    border-radius: 999px;
    background: var(--tf-black);
    color: var(--tf-white);
    border: 0;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--dur-fast) var(--ease-out);
  }
  .btn:hover { background: #222; color: var(--tf-white); }
  .btn .arr {
    width: 26px; height: 26px; border-radius: 999px;
    background: rgba(255,255,255,0.18);
    display: inline-grid; place-items: center;
  }
  .btn .arr svg { width: 13px; height: 13px; stroke-width: 2.2; }
  .btn--light { background: var(--tf-white); color: var(--tf-black); }
  .btn--light:hover { background: #fff; color: var(--tf-black); }
  .btn--light .arr { background: var(--tf-black); color: var(--tf-white); }
  .btn--outline {
    background: transparent;
    color: var(--tf-black);
    border: 1px solid rgba(0,0,0,0.28);
    padding: 11px 20px;
    gap: 12px;
  }
  .btn--outline:hover { background: transparent; color: var(--tf-black); border-color: var(--tf-black); }
  .btn--outline svg { width: 15px; height: 15px; stroke-width: 2; }

  /* ============ HERO ============ */
  .hero .wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: center;
    padding-top: 30px;
    padding-bottom: 0;
  }
  .hero-left { max-width: 540px; }
  .hero .eyebrow-red { margin-bottom: 26px; }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 60px;
    line-height: 1.04;
    letter-spacing: -0.025em;
    color: var(--tf-black);
    margin: 0;
  }
  .rotator { display: inline-grid; vertical-align: bottom; }
  .rotator > span {
    grid-area: 1 / 1;
    color: var(--tf-red);
    opacity: 0;
    will-change: opacity, transform;
    animation: tfWordCycle 8s infinite;
    animation-timing-function: var(--ease-in-out, cubic-bezier(.4,0,.2,1));
  }
  .rotator > span:nth-child(1) { animation-delay: 0s; }
  .rotator > span:nth-child(2) { animation-delay: 2s; }
  .rotator > span:nth-child(3) { animation-delay: 4s; }
  .rotator > span:nth-child(4) { animation-delay: 6s; }
  @keyframes tfWordCycle {
    0%   { opacity: 0; transform: translateY(0.16em); }
    8%   { opacity: 1; transform: translateY(0); }
    25%  { opacity: 1; transform: translateY(0); }
    33%  { opacity: 0; transform: translateY(-0.16em); }
    100% { opacity: 0; transform: translateY(-0.16em); }
  }
  @media (prefers-reduced-motion: reduce) {
    .rotator > span { animation: none; }
    .rotator > span:nth-child(1) { opacity: 1; }
    .rotator > span:nth-child(n+2) { display: none; }
  }
  .hero p.lede {
    margin: 26px 0 0;
    font-size: 17px;
    font-weight: var(--w-regular);
    line-height: 1.5;
    color: var(--tf-ink);
    max-width: 340px;
  }
  .hero p.bench {
    margin: 22px 0 0;
    font-size: 17px;
    font-weight: var(--w-regular);
    color: var(--tf-ink);
  }
  .hero-ctas { margin-top: 34px; display: flex; align-items: center; gap: 26px; }
  .play-row { display: inline-flex; align-items: center; gap: 12px; cursor: pointer; }
  .play-row .play {
    width: 34px; height: 34px; border-radius: 999px;
    border: 1.5px solid rgba(0,0,0,0.35);
    display: grid; place-items: center; color: var(--tf-black);
  }
  .play-row .play svg { width: 13px; height: 13px; }
  .play-row span {
    font-family: var(--font-body); font-weight: var(--w-medium); font-size: 15px; color: var(--tf-ink);
  }
  .hero-checks { margin-top: 30px; display: flex; flex-wrap: wrap; align-items: center; gap: 14px 28px; }
  .hcheck {
    display: inline-flex; align-items: center; gap: 9px;
    font-family: var(--font-body); font-weight: var(--w-medium); font-size: 14px; color: var(--tf-ink);
    white-space: nowrap;
  }
  .hcheck .ck {
    width: 18px; height: 18px; flex: 0 0 18px; border-radius: 999px;
    border: 1.5px solid var(--tf-red); color: var(--tf-red);
    display: grid; place-items: center;
  }
  .hcheck .ck svg { width: 10px; height: 10px; stroke-width: 3; }

  .hero-right { position: relative; height: 720px; }
  .hero-circle {
    position: absolute;
    width: 470px; height: 470px;
    border-radius: 999px;
    background: #E8E1DA;
    top: 56px; left: 50%; transform: translateX(-50%);
    z-index: 0;
  }
  .hero-dots {
    position: absolute;
    width: 270px; height: 520px;
    right: -36px; top: 180px;
    background-image: radial-gradient(var(--tf-red) 1.5px, transparent 1.7px);
    background-size: 12px 12px;
    -webkit-mask-image: radial-gradient(ellipse 60% 45% at 45% 55%, #000 0, #000 30%, transparent 78%);
            mask-image: radial-gradient(ellipse 60% 45% at 45% 55%, #000 0, #000 30%, transparent 78%);
    opacity: 0.9;
    z-index: 1;
    animation: tfDotsWave 18s ease-in-out infinite;
    will-change: background-position, filter;
  }
  @keyframes tfDotsWave {
    0%   { background-position: 0 0;      filter: blur(0px);   opacity: 0.92; }
    20%  { background-position: 12px 6px;  filter: blur(2px);   opacity: 0.6; }
    40%  { background-position: 0 12px;    filter: blur(0px);   opacity: 0.92; }
    60%  { background-position: -12px 18px; filter: blur(2px);  opacity: 0.6; }
    80%  { background-position: 0 30px;    filter: blur(0px);   opacity: 0.92; }
    100% { background-position: 0 36px;    filter: blur(0px);   opacity: 0.92; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-dots { animation: none; }
  }
  .hero-spark {
    position: absolute;
    width: 60px; height: 70px;
    left: 118px; top: 150px;
    z-index: 3;
  }
  .hero-figure {
    position: absolute;
    bottom: 0; left: 50%; transform: translateX(-50%);
    height: 720px; width: auto;
    z-index: 2;
  }

  /* ============ TRUSTED ============ */
  .trusted { background: var(--band); }
  .trusted .wrap { padding-top: 58px; padding-bottom: 58px; }
  .trusted .label {
    text-align: center;
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    font-weight: var(--w-bold); color: var(--tf-ink);
    margin-bottom: 18px;
  }
  .logos {
    position: relative; overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 7%, #000 93%, transparent 100%);
            mask-image: linear-gradient(to right, transparent 0, #000 7%, #000 93%, transparent 100%);
  }
  .logos-track { display: flex; width: max-content; animation: tfMarquee 32s linear infinite; }
  .logos:hover .logos-track { animation-play-state: paused; }
  .logos-set { display: flex; align-items: center; gap: 84px; padding-right: 84px; flex: 0 0 auto; }
  .logos .logo { flex: 0 0 auto; display: flex; align-items: center; }
  .logos .logo img { height: 32px; width: auto; object-fit: contain; filter: contrast(1.1); }
  .logos .logo.baejuice img { height: 40px; }
  @keyframes tfMarquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* ============ PLATFORM ============ */
  .platform .wrap { padding-top: 70px; padding-bottom: 70px; display: grid; grid-template-columns: 300px 1fr; gap: 60px; align-items: start; }
  .platform-left { padding-top: 6px; }
  .platform-left .eyebrow-red { margin-bottom: 22px; }
  .platform-left h2 {
    font-family: var(--font-display); font-weight: 700;
    font-size: 32px; line-height: 1.08; letter-spacing: -0.02em;
    color: var(--tf-black); margin: 0 0 18px;
  }
  .platform-left p:not(.eyebrow-red) {
    font-size: 15px; line-height: 1.5; color: var(--tf-ink); font-weight: var(--w-regular);
    margin: 0 0 26px; max-width: 250px;
  }
  .feat-list { display: flex; flex-direction: column; gap: 16px; }
  .feat {
    display: flex; align-items: center; gap: 12px;
    font-size: 15px; font-weight: var(--w-medium); color: var(--tf-ink);
  }
  .feat .ck {
    width: 20px; height: 20px; flex: 0 0 20px; border-radius: 999px;
    border: 1.5px solid var(--tf-red); color: var(--tf-red);
    display: grid; place-items: center;
  }
  .feat .ck svg { width: 11px; height: 11px; stroke-width: 3; }

  /* ---- dashboard ---- */
  .dash {
    background: var(--dash); border-radius: 10px; overflow: hidden;
    color: #fff; font-family: var(--font-body);
    box-shadow: 0 30px 60px rgba(0,0,0,0.18);
    transform: scale(1.15);
    transform-origin: center;
  }
  .dash-top {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 18px; border-bottom: 1px solid var(--dash-line);
  }
  .dash-top .dm { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: #fff; }
  .dash-top .crumb { font-size: 12.5px; color: rgba(255,255,255,0.62); white-space: nowrap; }
  .dash-top .crumb b { color: rgba(255,255,255,0.92); font-weight: var(--w-semibold); }
  .dash-top .spacer { flex: 1; }
  .dash-top .pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; color: rgba(255,255,255,0.8);
    border: 1px solid var(--dash-line); border-radius: 6px; padding: 6px 10px;
    white-space: nowrap;
  }
  .dash-top .pill svg { width: 13px; height: 13px; }
  .dash-body { display: grid; grid-template-columns: 120px 1fr; }
  .dash-side { padding: 16px 10px; border-right: 1px solid var(--dash-line); display: flex; flex-direction: column; gap: 3px; }
  .dash-side a {
    display: flex; align-items: center; gap: 9px;
    font-size: 12.5px; color: rgba(255,255,255,0.55);
    padding: 7px 9px; border-radius: 6px; text-decoration: none; border: 0;
    position: relative;
  }
  .dash-side a svg { width: 14px; height: 14px; }
  .dash-side a.on { color: var(--tf-red); }
  .dash-side a.on::before { content:''; position: absolute; left: -10px; top: 6px; bottom: 6px; width: 2px; background: var(--tf-red); }
  .dash-main { padding: 16px; display: grid; gap: 12px; }
  .dash-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .dcard { border: 1px solid var(--dash-line); border-radius: 8px; padding: 14px; }
  .dcard h4 { font-family: var(--font-body); font-weight: var(--w-semibold); font-size: 12px; color: rgba(255,255,255,0.85); margin: 0 0 10px; letter-spacing: 0; }
  .dscore { display: flex; align-items: flex-start; gap: 16px; }
  .dscore-num { font-family: var(--font-display); font-weight: 700; font-size: 46px; line-height: 0.9; color: #fff; }
  .dscore-lbl { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 4px; }
  .dscore-chart { flex: 1; }
  .dscore-chart svg { width: 100%; height: 60px; display: block; }
  .dscore-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 8px; }
  .dscore-foot .delta { font-size: 11px; color: var(--tf-red); display: inline-flex; align-items: center; gap: 4px; white-space: nowrap; }
  .dscore-foot .delta svg { width: 11px; height: 11px; }
  .dscore-foot .avg { font-size: 11px; color: rgba(255,255,255,0.5); }
  .dtake { display: flex; flex-direction: column; gap: 12px; }
  .dtake .row { display: flex; align-items: flex-start; gap: 9px; font-size: 12.5px; color: rgba(255,255,255,0.8); line-height: 1.3; }
  .dtake .ck { width: 16px; height: 16px; flex: 0 0 16px; border-radius: 999px; border: 1.4px solid rgba(255,255,255,0.4); color: rgba(255,255,255,0.7); display: grid; place-items: center; margin-top: 1px; }
  .dtake .ck svg { width: 9px; height: 9px; stroke-width: 3; }
  .dsplit { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .dstat { flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .dstat .r { display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: rgba(255,255,255,0.65); }
  .dstat .r span { white-space: nowrap; }
  .dstat .r b { color: #fff; font-weight: var(--w-semibold); }
  .ddonut { width: 76px; height: 76px; border-radius: 999px; position: relative; flex: 0 0 76px; }
  .ddonut::after { content:''; position: absolute; inset: 22px; border-radius: 999px; background: var(--dash-card); }

  /* ---- dashboard reveal animations ---- */
  @property --donut-sweep { syntax: '<angle>'; inherits: false; initial-value: 0deg; }
  .trendline { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .dscore-chart circle { opacity: 0; }
  .ddonut {
    -webkit-mask-image: conic-gradient(#000 var(--donut-sweep), transparent 0);
            mask-image: conic-gradient(#000 var(--donut-sweep), transparent 0);
    --donut-sweep: 0deg;
  }
  .dash.in-view .trendline { animation: tfDrawLine 1100ms var(--ease-out) 160ms forwards; }
  .dash.in-view .dscore-chart circle { animation: tfDotIn 300ms var(--ease-out) forwards; }
  .dash.in-view .dscore-chart circle:nth-of-type(1) { animation-delay: 360ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(2) { animation-delay: 460ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(3) { animation-delay: 560ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(4) { animation-delay: 660ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(5) { animation-delay: 760ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(6) { animation-delay: 860ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(7) { animation-delay: 960ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(8) { animation-delay: 1060ms; }
  .dash.in-view .dscore-chart circle:nth-of-type(9) { animation-delay: 1160ms; }
  .dash.in-view .ddonut { animation: tfDonutSweep 900ms var(--ease-out) 300ms forwards; }
  @keyframes tfDrawLine { to { stroke-dashoffset: 0; } }
  @keyframes tfDotIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes tfDonutSweep { from { --donut-sweep: 0deg; } to { --donut-sweep: 360deg; } }
  @media (prefers-reduced-motion: reduce) {
    .trendline { stroke-dashoffset: 0; }
    .dscore-chart circle { opacity: 1; }
    .ddonut { --donut-sweep: 360deg; }
    .dash.in-view .trendline, .dash.in-view .dscore-chart circle, .dash.in-view .ddonut { animation: none; }
  }
  .dquote { display: flex; align-items: flex-end; justify-content: space-between; gap: 14px; }
  .dquote .q { flex: 1; }
  .dquote .qt { font-family: var(--font-display); font-style: italic; font-size: 17px; line-height: 1.3; color: #fff; display: flex; gap: 6px; }
  .dquote .qt .mark { color: var(--tf-red); font-size: 22px; line-height: 1; }
  .dquote .qby { font-size: 11.5px; color: rgba(255,255,255,0.55); margin-top: 10px; display: inline-flex; align-items: center; gap: 6px; }
  .dquote .qby svg { width: 12px; height: 12px; }
  .dquote .thumbs { display: flex; align-items: flex-end; gap: 0; position: relative; }
  .dquote .thumbs .thumb-slot { width: 56px; height: 76px; display: block; border: 1px solid var(--dash-line); background: rgba(255,255,255,0.04); border-radius: 3px; }
  .dquote .thumbs .thumb-slot:last-child { margin-left: -20px; margin-bottom: 10px; }

  /* ============ WHY TEAMS ============ */
  .why .wrap { padding-top: 10px; padding-bottom: 70px; }
  .sec-head-center { text-align: center; }
  .sec-head-center h2 {
    font-family: var(--font-display); font-weight: 700;
    font-size: 44px; letter-spacing: -0.02em; color: var(--tf-black); margin: 0 0 40px;
  }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .why-col { padding: 0 28px; }
  .why-col + .why-col { border-left: 1px solid var(--line); }
  .why-col .ic { color: var(--tf-red); margin-bottom: 20px; }
  .why-col .ic svg { width: 30px; height: 30px; stroke-width: 1.6; }
  .why-col h3 { font-family: var(--font-body); font-weight: var(--w-bold); font-size: 16px; color: var(--tf-black); margin: 0 0 12px; letter-spacing: 0; line-height: 1.2; }
  .why-col p { font-size: 14px; line-height: 1.5; color: var(--tf-ink); font-weight: var(--w-regular); margin: 0; }

  /* ============ WHAT GETS TESTED ============ */
  .tested .wrap { padding-bottom: 70px; }
  .tested-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
  .tested-head h2 { font-family: var(--font-display); font-weight: 700; font-size: 40px; letter-spacing: -0.02em; color: var(--tf-black); margin: 0; }
  .tested-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
  .tcard { background: var(--card); border: 1px solid var(--line); border-radius: 8px; padding: 14px; display: flex; gap: 16px; min-height: 192px; }
  .tcard .pic { width: 124px; flex: 0 0 124px; border-radius: 4px; overflow: hidden; background: transparent; }
  .tcard .pic img { width: 100%; height: 100%; object-fit: contain; }
  .tcard .info { flex: 1; display: flex; flex-direction: column; }
  .tcard .lbl { font-family: var(--font-display); font-weight: 700; font-size: 30px; line-height: 1.02; letter-spacing: -0.02em; color: var(--tf-black); margin-bottom: 10px; }
  .tcard .desc { font-size: 12.5px; line-height: 1.45; color: var(--tf-ink); font-weight: var(--w-regular); }
  .tcard .go { margin-top: auto; align-self: flex-end; color: var(--tf-red); }
  .tcard .go svg { width: 16px; height: 16px; }

  /* ============ CTA BAND ============ */
  .cta .wrap { padding-bottom: 70px; }
  .cta-band {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 30px 40px;
    display: grid;
    grid-template-columns: 150px 1fr auto;
    align-items: center;
    gap: 36px;
  }
  .cta-visual { position: relative; height: 124px; }
  .cta-circle {
    position: absolute;
    width: 104px; height: 104px; border-radius: 999px;
    background: var(--tf-red);
    left: 44px; bottom: -6px; z-index: 0;
  }
  .cta-spark { position: absolute; width: 52px; height: 58px; left: -8px; top: 0; z-index: 2; }
  .cta-visual img { position: absolute; left: 10px; top: 0; height: 124px; width: auto; z-index: 1; transform: rotate(-8deg); }
  .cta-copy h2 {
    font-family: var(--font-display); font-weight: 700;
    font-size: 28px; line-height: 1.1; letter-spacing: -0.02em;
    color: var(--tf-black); margin: 0 0 8px;
  }
  .cta-copy p { font-size: 15px; line-height: 1.5; color: var(--tf-stone); font-weight: var(--w-regular); margin: 0; max-width: 420px; }
  .cta-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 14px; }

  /* ============ HOW IT WORKS ============ */
  .how .wrap { padding-bottom: 70px; }
  .how .sec-head-center h2 { margin-bottom: 36px; }
  .how-grid { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; align-items: start; gap: 18px; }
  .how-step { display: flex; gap: 18px; align-items: flex-start; }
  .how-step .circ {
    width: 64px; height: 64px; flex: 0 0 64px; border-radius: 999px;
    background: var(--band); display: grid; place-items: center; color: var(--tf-black);
  }
  .how-step .circ svg { width: 26px; height: 26px; stroke-width: 1.6; }
  .how-step .num { font-family: var(--font-display); font-weight: 700; font-size: 15px; color: var(--tf-red); margin: 0 0 6px; }
  .how-step h3 { font-family: var(--font-body); font-weight: var(--w-bold); font-size: 16px; color: var(--tf-black); margin: 0 0 8px; letter-spacing: 0; }
  .how-step p { font-size: 13.5px; line-height: 1.5; color: var(--tf-ink); font-weight: var(--w-regular); margin: 0; }
  .chips { display: flex; gap: 6px; margin-top: 12px; }
  .chips span { font-size: 10px; letter-spacing: 0.06em; font-weight: var(--w-bold); color: var(--tf-stone); background: var(--band); border-radius: 4px; padding: 4px 8px; }
  .how-arrow { align-self: center; color: var(--tf-fog); padding-top: 14px; }
  .how-arrow svg { width: 22px; height: 22px; }

  /* ============ DEMO ============ */
  .demo .wrap { padding-bottom: 70px; }
  .demo-panel { background: var(--dash); border-radius: 10px; overflow: hidden; display: grid; grid-template-columns: 320px 1fr; align-items: stretch; }
  .demo-text { padding: 40px 36px; align-self: center; }
  .demo-text .eyebrow-red { margin-bottom: 16px; }
  .demo-text h2 { font-family: var(--font-display); font-weight: 700; font-size: 42px; line-height: 0.98; letter-spacing: -0.02em; color: #fff; margin: 0 0 16px; }
  .demo-text p { font-size: 14px; color: rgba(255,255,255,0.7); margin: 0 0 26px; }
  .demo-stage { position: relative; overflow: hidden; display: flex; align-items: center; }
  .demo-stage img { width: 100%; height: auto; display: block; }

  /* ============ FOOTER ============ */
  .site-footer { background: var(--dash); color: rgba(255,255,255,0.7); }
  .site-footer .wrap { padding-top: 44px; padding-bottom: 26px; }
  .foot-grid { display: grid; grid-template-columns: 1.7fr 1fr 1.2fr; gap: 28px; }
  .foot-brand .fm { display: inline-flex; align-items: flex-end; margin-bottom: 16px; }
  .foot-brand .fm img { height: 20px; width: auto; display: block; filter: invert(1); }
  .foot-brand p { font-size: 13.5px; line-height: 1.4; color: rgba(255,255,255,0.55); margin: 0 0 18px; max-width: 180px; }
  .foot-social { display: flex; gap: 10px; }
  .foot-social a { width: 30px; height: 30px; border-radius: 999px; background: rgba(255,255,255,0.08); display: grid; place-items: center; color: #fff; border: 0; }
  .foot-social a svg { width: 14px; height: 14px; }
  .foot-social a:hover { background: var(--tf-red); }
  .foot-nav { display: flex; flex-direction: column; gap: 11px; padding-top: 2px; }
  .foot-col h4 { font-family: var(--font-body); font-weight: var(--w-bold); font-size: 13px; color: #fff; margin: 0 0 16px; letter-spacing: 0; }
  .foot-col a { display: block; font-size: 13px; color: rgba(255,255,255,0.6); text-decoration: none; border: 0; margin-bottom: 11px; }
  .foot-col a:hover { color: #fff; }
  .foot-signup h4 { font-family: var(--font-body); font-weight: var(--w-bold); font-size: 13px; color: #fff; margin: 0 0 16px; }
  .foot-priv { display: block; font-size: 13px; color: rgba(255,255,255,0.6); text-decoration: none; border: 0; margin-bottom: 11px; }
  .foot-priv:hover { color: #fff; }
  .foot-signup .field { display: flex; background: rgba(255,255,255,0.07); border: 1px solid var(--dash-line); border-radius: 6px; overflow: hidden; }
  .foot-signup input { flex: 1; background: transparent; border: 0; outline: 0; color: #fff; font: inherit; font-size: 13px; padding: 10px 12px; }
  .foot-signup input::placeholder { color: rgba(255,255,255,0.45); }
  .foot-signup button { background: transparent; border: 0; color: var(--tf-red); padding: 0 12px; cursor: pointer; display: grid; place-items: center; }
  .foot-signup button svg { width: 16px; height: 16px; }
  .foot-signup-msg { margin: 12px 0 0; font-size: 12.5px; line-height: 1.4; display: flex; align-items: center; gap: 7px; }
  .foot-signup-msg.ok { color: #fff; }
  .foot-signup-msg.err { color: var(--tf-red); }
  .foot-signup-msg .mi { display: inline-grid; place-items: center; width: 16px; height: 16px; flex: 0 0 16px; }
  .foot-signup-msg.ok .mi { color: #4ED07A; }
  .foot-signup-msg .mi svg { width: 14px; height: 14px; stroke-width: 3; }
  .foot-signup.done .field { display: none; }
  .foot-bottom { display: flex; align-items: center; justify-content: flex-end; margin-top: 36px; padding-top: 18px; border-top: 1px solid var(--dash-line); }
  .foot-bottom .cp { font-size: 11.5px; color: rgba(255,255,255,0.4); white-space: nowrap; }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1000px) {
    /* nav -> mobile dropdown */
    .nav {
      position: absolute; top: 100%; left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: 0;
      background: var(--page); border-top: 1px solid var(--line);
      padding: 6px 0 12px; margin: 0; display: none; z-index: 60;
      box-shadow: 0 24px 40px rgba(0,0,0,0.10);
    }
    .site-header.open .nav { display: flex; }
    .nav a:not(.btn) { padding: 14px 40px; font-size: 16px; }
    .nav a:not(.nav-cta):not(:last-child) { border-bottom: 1px solid var(--line); }
    .nav a.nav-cta { display: inline-flex; margin: 12px 40px 0; }
    .site-header .header-btn { display: none; }
    .nav-toggle { display: inline-grid; }

    .hero .wrap { grid-template-columns: 1fr; gap: 8px; padding-bottom: 0; align-items: start; }
    .hero-left { max-width: 620px; }
    .hero-right { height: 460px; }
    .hero-circle { width: 300px; height: 300px; top: 64px; right: auto; left: 50%; transform: translateX(-56%); }
    .hero-figure { height: 470px; right: auto; left: 50%; transform: translateX(-50%); }
    .hero-dots { width: 190px; height: 320px; top: 110px; right: -14px; }

    .platform .wrap { grid-template-columns: 1fr; gap: 28px; }
    .dash { transform: none; }
    .platform-left p { max-width: none; }
    .why-grid { grid-template-columns: 1fr 1fr; gap: 32px 0; }
    .why-col + .why-col { border-left: 0; }
    .why-col:nth-child(n+3) { border-top: 1px solid var(--line); padding-top: 32px; }
    .tested-grid { grid-template-columns: 1fr 1fr; }
    .how-grid { grid-template-columns: 1fr; gap: 28px; }
    .how-arrow { display: none; }
    .demo-panel { grid-template-columns: 1fr; }
    .demo-stage { display: block; }
    .cta-band { grid-template-columns: 110px 1fr; gap: 24px 28px; }
    .cta-actions { grid-column: 2; align-items: flex-start; }
    .cta-visual { height: 100px; }
    .cta-visual img { height: 96px; }
    .cta-circle { width: 80px; height: 80px; left: 18px; }
    .foot-grid { grid-template-columns: 1fr 1fr; gap: 28px 24px; }
    .foot-brand, .foot-signup { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    /* phone */
    .wrap { padding: 0 20px; }
    .site-header { padding: 18px 0 14px; }
    .nav a:not(.btn) { padding-left: 20px; padding-right: 20px; }
    .nav a.nav-cta { margin-left: 20px; margin-right: 20px; }

    .hero .eyebrow-red { margin-bottom: 16px; }
    .hero h1 { font-size: 44px; }
    .hero p.lede, .hero p.bench { font-size: 16px; }
    .hero p.lede { max-width: none; }
    .hero-ctas { margin-top: 26px; flex-direction: column; align-items: stretch; gap: 12px; }
    .hero-ctas .btn { width: 100%; justify-content: space-between; }
    .hero-right { height: 360px; }
    .hero-circle { width: 230px; height: 230px; top: 44px; }
    .hero-figure { height: 360px; }
    .hero-dots { display: none; }

    .platform .wrap { padding-top: 48px; padding-bottom: 48px; }
    .platform-left h2 { font-size: 28px; }
    .sec-head-center h2 { font-size: 28px; margin-bottom: 28px; }
    .why .wrap { padding-bottom: 48px; }
    .why-grid { grid-template-columns: 1fr; gap: 0; }
    .why-col { padding: 24px 0 0; }
    .why-col:first-child { padding-top: 0; }
    .why-col + .why-col { border-left: 0; border-top: 1px solid var(--line); }
    .why-col:nth-child(n+3) { padding-top: 24px; }
    .tested .wrap { padding-bottom: 48px; }
    .tested-head { flex-direction: column; align-items: flex-start; gap: 10px; }
    .tested-head h2 { font-size: 28px; }
    .tested-grid { grid-template-columns: 1fr; }
    .how .wrap { padding-bottom: 48px; }
    .demo .wrap { padding-bottom: 48px; }
    .cta .wrap { padding-bottom: 48px; }
    .cta-band { grid-template-columns: 1fr; text-align: left; padding: 26px 24px; gap: 20px; }
    .cta-visual { display: none; }
    .cta-actions { grid-column: 1; align-items: stretch; }
    .cta-actions .btn { width: 100%; justify-content: space-between; }
    .cta-copy p { max-width: none; }
    .demo-text { padding: 32px 24px; }
    .demo-text h2 { font-size: 34px; }
    .foot-grid { grid-template-columns: 1fr 1fr; }

    /* dashboard reflow */
    .dash-top { flex-wrap: wrap; gap: 8px 10px; }
    .dash-top .spacer { display: none; }
    .dash-top .crumb { order: 3; width: 100%; }
    .dash-top .pill { font-size: 11px; padding: 5px 8px; }
    .dash-body { grid-template-columns: 1fr; }
    .dash-side { flex-direction: row; flex-wrap: wrap; border-right: 0; border-bottom: 1px solid var(--dash-line); gap: 2px; }
    .dash-side a.on::before { display: none; }
    .dash-row { grid-template-columns: 1fr; }
    .dscore-num { font-size: 40px; }
  }
</style>
</head>
<body>

  <!-- ===== HEADER ===== -->
  <header class="site-header" id="siteHeader">
    <div class="wrap">
      <a class="wordmark" href="/"><img src="/assets/logo-primary.png" alt="testfeed" /><span class="logodot"></span></a>
      <nav class="nav" id="nav">
        <a href="#platform">Product</a>
        <a href="/use-cases/">Use cases</a>
        <a href="/contact">Pricing</a>
        <a href="/contact">Contact</a>
        <a class="btn nav-cta" href={bookingUrl} target="_blank" rel="noopener">Book a demo <span class="arr"><i data-lucide="arrow-right"></i></span></a>
      </nav>
      <a class="btn header-btn" href={bookingUrl} target="_blank" rel="noopener">Book a demo <span class="arr"><i data-lucide="arrow-right"></i></span></a>
      <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false"><i data-lucide="menu"></i></button>
    </div>
  </header>

  <!-- ===== HERO ===== -->
  <section class="hero" data-screen-label="Hero">
    <div class="wrap">
      <div class="hero-left">
        <p class="eyebrow-red">AI respondents. Built from real audience data.</p>
        <h1>
          <span class="rotator" aria-label="Customer">
            <span>Customer</span>
            <span>Shopper</span>
            <span>Audience</span>
            <span>Buyer</span>
          </span><br/>
          feedback<br/>
          on-demand<span class="dot-red">.</span>
        </h1>
        <p class="lede">We build an AI panel of your audience, so you can ask them anything, at any time.</p>
        <div class="hero-ctas">
          <a class="btn" href={bookingUrl} target="_blank" rel="noopener">Book a demo <span class="arr"><i data-lucide="arrow-right"></i></span></a>
          <a class="btn btn--outline" href="#platform">See TestFeed in action <i data-lucide="arrow-right"></i></a>
        </div>
        <div class="hero-checks">
          <span class="hcheck"><span class="ck"><i data-lucide="check"></i></span>Real audience data</span>
          <span class="hcheck"><span class="ck"><i data-lucide="check"></i></span>Human-benchmarked</span>
          <span class="hcheck"><span class="ck"><i data-lucide="check"></i></span>Enterprise secure</span>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-circle"></div>
        <div class="hero-dots"></div>
        <img class="hero-figure" src="/assets/hero-figure-full.png" alt="1950s housewife holding a Sunny Crisp Corn Flakes box" />
      </div>
    </div>
  </section>

  <!-- ===== TRUSTED ===== -->
  <section class="trusted">
    <div class="wrap">
      <div class="label">Trusted by leading teams</div>
      <div class="logos">
        <div class="logos-track">
          <div class="logos-set">
            <div class="logo andie"><img src="/assets/logo-andie-t.png" alt="Andie" /></div>
            <div class="logo clutch"><img src="/assets/logo-clutch-t.png" alt="Clutch" /></div>
            <div class="logo baejuice"><img src="/assets/logo-baejuice-t.png" alt="Bae Juice" /></div>
            <div class="logo solbevi"><img src="/assets/logo-solbevi-t.png" alt="Solbeví" /></div>
            <div class="logo elita"><img src="/assets/logo-elita-t.png" alt="Elita" /></div>
          </div>
          <div class="logos-set" aria-hidden="true">
            <div class="logo andie"><img src="/assets/logo-andie-t.png" alt="" /></div>
            <div class="logo clutch"><img src="/assets/logo-clutch-t.png" alt="" /></div>
            <div class="logo baejuice"><img src="/assets/logo-baejuice-t.png" alt="" /></div>
            <div class="logo solbevi"><img src="/assets/logo-solbevi-t.png" alt="" /></div>
            <div class="logo elita"><img src="/assets/logo-elita-t.png" alt="" /></div>
          </div>
          <div class="logos-set" aria-hidden="true">
            <div class="logo andie"><img src="/assets/logo-andie-t.png" alt="" /></div>
            <div class="logo clutch"><img src="/assets/logo-clutch-t.png" alt="" /></div>
            <div class="logo baejuice"><img src="/assets/logo-baejuice-t.png" alt="" /></div>
            <div class="logo solbevi"><img src="/assets/logo-solbevi-t.png" alt="" /></div>
            <div class="logo elita"><img src="/assets/logo-elita-t.png" alt="" /></div>
          </div>
          <div class="logos-set" aria-hidden="true">
            <div class="logo andie"><img src="/assets/logo-andie-t.png" alt="" /></div>
            <div class="logo clutch"><img src="/assets/logo-clutch-t.png" alt="" /></div>
            <div class="logo baejuice"><img src="/assets/logo-baejuice-t.png" alt="" /></div>
            <div class="logo solbevi"><img src="/assets/logo-solbevi-t.png" alt="" /></div>
            <div class="logo elita"><img src="/assets/logo-elita-t.png" alt="" /></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PLATFORM / DASHBOARD ===== -->
  <section class="platform" id="platform" data-screen-label="Platform">
    <div class="wrap">
      <div class="platform-left">
        <p class="eyebrow-red">Platform</p>
        <h2>See exactly what<br/>your audience thinks.</h2>
        <p>Upload anything. Get a score, the quotes, and the next move.</p>
        <div class="feat-list">
          <div class="feat"><span class="ck"><i data-lucide="check"></i></span>Score and trend</div>
          <div class="feat"><span class="ck"><i data-lucide="check"></i></span>Emotions and reactions</div>
          <div class="feat"><span class="ck"><i data-lucide="check"></i></span>Audience quotes</div>
          <div class="feat"><span class="ck"><i data-lucide="check"></i></span>Purchase intent</div>
          <div class="feat"><span class="ck"><i data-lucide="check"></i></span>The next move</div>
        </div>
      </div>

      <div class="dash" aria-hidden="true">
        <div class="dash-top">
          <span class="dm">testfeed</span>
          <span class="crumb">Concept Test · <b>Sunny Crisp Cereal</b></span>
          <span class="spacer"></span>
          <span class="pill"><i data-lucide="upload"></i> Export</span>
          <span class="pill">Last 30 days <i data-lucide="chevron-down"></i></span>
        </div>
        <div class="dash-body">
          <div class="dash-side">
            <a class="on"><i data-lucide="layout-dashboard"></i> Overview</a>
            <a><i data-lucide="message-square"></i> Responses</a>
            <a><i data-lucide="users"></i> Audience</a>
            <a><i data-lucide="bar-chart-3"></i> Benchmarks</a>
            <a><i data-lucide="file-text"></i> Reports</a>
            <a><i data-lucide="flask-conical"></i> Tests</a>
            <a><i data-lucide="settings"></i> Settings</a>
          </div>
          <div class="dash-main">
            <div class="dash-row">
              <div class="dcard">
                <h4>Top 2 Box Score</h4>
                <div class="dscore">
                  <div>
                    <div class="dscore-num">87%</div>
                    <div class="dscore-lbl">Very Strong</div>
                  </div>
                  <div class="dscore-chart">
                    <svg viewBox="0 0 200 56" preserveAspectRatio="none">
                      <polyline class="trendline" pathLength="1" fill="none" stroke="#E6392E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                        points="4,48 26,42 48,44 70,34 92,36 114,26 136,30 158,18 180,14 196,6" />
                      <circle cx="26" cy="42" r="2.4" fill="#E6392E"/><circle cx="48" cy="44" r="2.4" fill="#E6392E"/>
                      <circle cx="70" cy="34" r="2.4" fill="#E6392E"/><circle cx="92" cy="36" r="2.4" fill="#E6392E"/>
                      <circle cx="114" cy="26" r="2.4" fill="#E6392E"/><circle cx="136" cy="30" r="2.4" fill="#E6392E"/>
                      <circle cx="158" cy="18" r="2.4" fill="#E6392E"/><circle cx="180" cy="14" r="2.4" fill="#E6392E"/>
                      <circle cx="196" cy="6" r="3" fill="#E6392E"/>
                    </svg>
                  </div>
                </div>
                <div class="dscore-foot">
                  <span class="delta"><i data-lucide="trending-up"></i> 11% vs last 30 days</span>
                  <span class="avg">87% Avg</span>
                </div>
              </div>
              <div class="dcard">
                <h4>Key takeaways</h4>
                <div class="dtake">
                  <div class="row"><span class="ck"><i data-lucide="check"></i></span>Strong visual appeal and shelf standout.</div>
                  <div class="row"><span class="ck"><i data-lucide="check"></i></span>Health perception is a key purchase driver.</div>
                  <div class="row"><span class="ck"><i data-lucide="check"></i></span>Consider bolder flavor messaging.</div>
                </div>
              </div>
            </div>
            <div class="dash-row">
              <div class="dcard">
                <h4>Emotion</h4>
                <div class="dsplit">
                  <div class="dstat">
                    <div class="r"><span>Excited</span><b>46%</b></div>
                    <div class="r"><span>Curious</span><b>22%</b></div>
                    <div class="r"><span>Trusting</span><b>14%</b></div>
                    <div class="r"><span>Other</span><b>6%</b></div>
                  </div>
                  <div class="ddonut" style="background: conic-gradient(#E6392E 0 46%, rgba(255,255,255,0.55) 46% 68%, rgba(255,255,255,0.32) 68% 82%, rgba(255,255,255,0.16) 82% 100%);"></div>
                </div>
              </div>
              <div class="dcard">
                <h4>Purchase intent</h4>
                <div class="dsplit">
                  <div class="dstat">
                    <div class="r"><span>Definitely</span><b>38%</b></div>
                    <div class="r"><span>Likely</span><b>45%</b></div>
                    <div class="r"><span>Maybe</span><b>12%</b></div>
                    <div class="r"><span>Not likely</span><b>5%</b></div>
                  </div>
                  <div class="ddonut" style="background: conic-gradient(#E6392E 0 38%, rgba(255,255,255,0.55) 38% 83%, rgba(255,255,255,0.32) 83% 95%, rgba(255,255,255,0.16) 95% 100%);"></div>
                </div>
              </div>
            </div>
            <div class="dcard">
              <h4>Audience quote</h4>
              <div class="dquote">
                <div class="q">
                  <div class="qt"><span class="mark">“</span><span>I love the clean look and feel like it's a healthier option. I'd definitely try this.”</span></div>
                  <div class="qby"><i data-lucide="user"></i> Female, 34, Midwest</div>
                </div>
                <div class="thumbs">
                  <span class="thumb-slot"></span>
                  <span class="thumb-slot"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
