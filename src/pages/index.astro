  /* Solution Section */
  .solution-section {
    padding: var(--spacing-xxl) 0;
    position: relative;
    background: linear-gradient(180deg, #0a0a0a 0%, #1a1a1a 100%);
    overflow: hidden;
  }

  .solution-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 255, 255, 0.05) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  .solution-header {
    text-align: center;
    margin-bottom: var(--spacing-xxl);
  }

  .solution-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-white);
