<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Hero video player
    const heroVideoPlaceholder = document.getElementById(
      "hero-video-placeholder",
    );
    if (heroVideoPlaceholder) {
      const videoWrapper = heroVideoPlaceholder.closest(".video-wrapper");

      heroVideoPlaceholder.addEventListener("click", loadHeroVideo);
      heroVideoPlaceholder.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          loadHeroVideo();
        }
      });

      function loadHeroVideo() {
        if (!videoWrapper) return;

        const iframe = document.createElement("iframe");
        iframe.setAttribute("width", "100%");
        iframe.setAttribute("height", "100%");
        iframe.setAttribute(
          "src",
          "https://www.youtube.com/embed/j6SDj67J5fM?autoplay=1&rel=0",
        );
        iframe.setAttribute("title", "TestFeed Demo Video");
        iframe.setAttribute(
          "allow",
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share",
        );
        iframe.setAttribute("allowfullscreen", "");
        iframe.style.borderRadius = "12px";
        iframe.style.display = "block";

        videoWrapper.innerHTML = "";
        videoWrapper.appendChild(iframe);
      }
    }

    // Chat feedback message rotation
    const feedbackMessages = [
      "I don't get it",
      "This doesn't make sense",
      "Hmm, that's cool",
      "Love this approach",
      "Not sure about this",
    ];

    let currentMessageIndex = 0;
    const feedbackMessageEl = document.getElementById(
      "feedback-message",
    ) as HTMLElement;
    const loadingMessageEl = document.querySelector(
      ".loading-message",
    ) as HTMLElement;

    function rotateFeedbackMessage() {
      if (!feedbackMessageEl || !loadingMessageEl) return;

      // Hide current message completely
      feedbackMessageEl.style.display = "none";
      feedbackMessageEl.style.opacity = "0";

      // Show loading
      loadingMessageEl.style.display = "block";

      setTimeout(() => {
        // Update message while loading is showing
        currentMessageIndex =
          (currentMessageIndex + 1) % feedbackMessages.length;
        feedbackMessageEl.textContent = feedbackMessages[currentMessageIndex];

        // Hide loading
        loadingMessageEl.style.display = "none";

        // Show new message with animation
        feedbackMessageEl.style.display = "block";
        feedbackMessageEl.style.animation = "none";

        // Force reflow to restart animation
        void feedbackMessageEl.offsetWidth;

        feedbackMessageEl.style.animation =
          "fadeInMessage 0.5s ease-out forwards";
      }, 1500); // Loading duration
    }

    // Initialize - hide loading, show first message
    if (feedbackMessageEl && loadingMessageEl) {
      loadingMessageEl.style.display = "none";
      feedbackMessageEl.style.display = "block";
      feedbackMessageEl.style.opacity = "1";

      // Start rotation
      setInterval(rotateFeedbackMessage, 4000); // Rotate every 4 seconds
    }

    // Use cases carousel
    const slides = document.querySelectorAll(".use-case-slide");
    const dots = document.querySelectorAll(".carousel-dot");
    let currentSlide = 0;

    function showSlide(index: number) {
      slides.forEach((slide) => slide.classList.remove("active"));
      dots.forEach((dot) => dot.classList.remove("active"));

      slides[index].classList.add("active");
      dots[index].classList.add("active");
      currentSlide = index;
    }

    function nextSlide() {
      currentSlide = (currentSlide + 1) % slides.length;
      showSlide(currentSlide);
    }

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => showSlide(index));
    });

    // Show first slide
    if (slides.length > 0) {
      showSlide(0);
      // Auto-advance every 7 seconds
      setInterval(nextSlide, 7000);
    }

    // FAQ functionality
    const faqContainer = document.getElementById("faq");
    if (faqContainer) {
      const faqItems = faqContainer.querySelectorAll(".faq-item");
      if (faqItems.length > 0) {
        faqItems.forEach((item) => {
          const question = item.querySelector(".faq-question");
          if (!question) return;

          question.setAttribute("aria-expanded", "false");

          const answer = item.querySelector(".faq-answer");
          if (!answer) return;

          // Associate question with answer for screen readers
          const answerId = `faq-answer-${Math.random().toString(36).substring(2, 15)}`;
          answer.setAttribute("id", answerId);
          question.setAttribute("aria-controls", answerId);
          answer.setAttribute("aria-hidden", "true");

          const clickHandler = () => {
            const expanded = item.classList.contains("active");
            question.setAttribute("aria-expanded", String(!expanded));
            answer.setAttribute("aria-hidden", String(expanded));
            item.classList.toggle("active");

            // Close other items (accordion style)
            faqItems.forEach((otherItem) => {
              if (
                otherItem !== item &&
                otherItem.classList.contains("active")
              ) {
                otherItem.classList.remove("active");
                const otherQuestion = otherItem.querySelector(".faq-question");
                const otherAnswer = otherItem.querySelector(".faq-answer");
                if (otherQuestion)
                  otherQuestion.setAttribute("aria-expanded", "false");
                if (otherAnswer)
                  otherAnswer.setAttribute("aria-hidden", "true");
              }
            });
          };

          question.addEventListener("click", clickHandler);
        });
      }
    }

    // Floating cursors with random comments
    const startupComments = [
      "Obviously we're building this already",
      "This is just ChatGPT with extra steps",
      "We did this at my last unicorn",
      "Cool but where's the blockchain?",
      "This won't scale past 10k users",
      "My intern could build this in a weekend",
      "Why didn't they just use our API?",
      "We're disrupting this space harder",
      "This is so 2023",
      "Our solution is way more elegant",
      "They clearly don't understand PMF",
      "This is what we pivoted from",
      "We should just acquihire them",
      "Cute MVP but not enterprise-ready",
      "Our Series A pitch deck had this",
    ];

    const cfoComments = [
      "Can Marketing pay for half?",
      "We're already over on software spend",
      "Budget freeze until next quarter",
      "Show me the cost per employee",
      "Where's the business justification form?",
      "Is this compliant with policy 4.2?",
      "I need three vendor comparisons",
      "This requires committee approval",
      "Did you follow proper channels?",
      "I'll need Legal's sign-off first",
      "This wasn't in our approved budget",
      "We need quarterly usage reports",
      "Is there a volume discount available?",
      "I'll add this to next month's review",
      "This needs board notification",
    ];

    const genzComments = [
      "This is actually genius ngl",
      "Virtual personas hit different",
      "No cap this slaps",
      "Why didn't I think of this",
      "This would save my content",
      "My posts need this fr",
      "People's reactions = everything",
      "Testing before posting? Valid",
      "This is so necessary bestie",
      "My content flops need this",
      "Actually revolutionary",
      "This could change the game",
      "Need this for my brand",
      "Audience insight is chef's kiss",
      "Why am I not using this yet",
    ];

    const empathyComments = [
      "Wait... am I a persona?",
      "This is lowkey meta ngl",
      "I feel so seen... literally",
      "Can I get a persona to step out of my bubble?",
    ];

    const founderFollowUpComments = [
      "This sounds too desperate",
      "What's the business impact here?",
      "This guy's got no business sense",
      "I don't want to be followed up on",
    ];

    function showRandomComment(commentId: string) {
      const commentElement = document.getElementById(commentId);
      if (!commentElement) return;

      let comments;
      if (commentId === "comment-1") comments = startupComments;
      else if (commentId === "comment-2") comments = cfoComments;
      else if (commentId === "comment-3") comments = genzComments;
      else if (commentId === "founder-step2-comment")
        comments = founderFollowUpComments;
      else if (commentId === "empathy-comment") comments = empathyComments;
      else return;

      const randomComment =
        comments[Math.floor(Math.random() * comments.length)];
      commentElement.textContent = randomComment;
      commentElement.classList.add("show");

      setTimeout(() => {
        commentElement.classList.remove("show");
      }, 3000);
    }

    // Show random comments at intervals
    setInterval(() => showRandomComment("comment-1"), 8000);
    setInterval(() => showRandomComment("comment-2"), 12000);
    setInterval(() => showRandomComment("comment-3"), 15000);
    setInterval(() => showRandomComment("founder-step2-comment"), 5000);
    setInterval(() => showRandomComment("empathy-comment"), 10000);

    // Initial comments after page load
    setTimeout(() => showRandomComment("comment-1"), 3000);
    setTimeout(() => showRandomComment("comment-2"), 6000);
    setTimeout(() => showRandomComment("comment-3"), 9000);
    setTimeout(() => showRandomComment("founder-step2-comment"), 2000);
    setTimeout(() => showRandomComment("empathy-comment"), 4000);

    // Checkbox animation on scroll into view
    const checkboxElement = document.querySelector(
      ".suggestion-checkbox",
    ) as HTMLElement;
    if (checkboxElement) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (
              entry.isIntersecting &&
              !entry.target.classList.contains("animate")
            ) {
              entry.target.classList.add("animate");
            }
          });
        },
        {
          threshold: 0.5, // Trigger when 50% of the element is visible
        },
      );

      observer.observe(checkboxElement);
    }

    // Dropdown animation on scroll into view
    const dropdownElement = document.getElementById("audience-dropdown");
    if (dropdownElement) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (
              entry.isIntersecting &&
              !entry.target.classList.contains("animated")
            ) {
              entry.target.classList.add("animated");

              // Animate the selection after a short delay
              setTimeout(() => {
                const startupItem = document.getElementById(
                  "startup-founders-item",
                );

                if (startupItem) {
                  // Add selection animation to the item
                  startupItem.classList.add("animate-selection");

                  // After animation completes, add the final selected state
                  setTimeout(() => {
                    startupItem.classList.add("selected");
                  }, 500);
                }
              }, 500);
            }
          });
        },
        {
          threshold: 0.4, // Trigger when 40% of the element is visible
        },
      );

      observer.observe(dropdownElement);
    }
  });
</script>
