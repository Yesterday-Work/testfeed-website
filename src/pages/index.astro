    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
  }

  .center-badge {
    display: inline-block;
    color: var(--color-white);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-logo);
  }

  .card-highlight {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
    line-height: 1.3;
  }

  .center-detail {
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
  }

  .solution-footer {
