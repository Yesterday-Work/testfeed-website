      transform: scale(1) translateY(-4px);
    }

    .left-card,
    .right-card {
      opacity: 1;
    }

    .solution-header h2 {
      font-size: 2.25rem;
    }

    .solution-subtitle {
      font-size: 1.125rem;
    }
  }

  /* How it works Section */
  .how-it-works {
