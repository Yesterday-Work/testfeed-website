</BaseLayout>

<style>
/* Hero Section */
.hero {
    padding: var(--spacing-xxl) 0;
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, rgba(0, 0, 0, 0) 70%);
    z-index: -1;
    animation: pulse-bg 15s infinite;
}

@keyframes pulse-bg {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
}

.hero-content {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
}

.hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--spacing-lg);
    color: var(--color-text);
}

.hero-description {
    font-size: 1.2rem;
    margin-bottom: var(--spacing-lg);
    color: var(--color-text-light);
    line-height: 1.6;
}

.cta-buttons {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
}

.rotating-text {
    color: var(--color-text);
    position: relative;
    display: inline-block;
    min-width: 140px;
    text-align: left;
}

.react-emphasis {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0.04) 100%);
    padding: 2px 12px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    font-weight: 800;
    letter-spacing: -0.3px;
    position: relative;
    display: inline-block;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
}

.before-fade {
    color: var(--color-text-light);
    opacity: 0.6;
    font-weight: 800;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.3), 0 0 16px rgba(255, 255, 255, 0.2);
    filter: blur(0.3px);
    position: relative;
    display: inline-block;
    letter-spacing: 0.5px;
}

/* Floating Cursors */
.cursor-name {
    padding: 2px 6px;
    color: #FFF;
    font-size: 11px;
    display: inline-block;
    position: absolute;
    top: 24px;
    left: 20px;
    border-radius: 4px;
    font-weight: 500;
    white-space: nowrap;
}

.floating-cursor, .floating-cursor-2, .floating-cursor-3 {
    position: absolute;
    z-index: 10;
    pointer-events: none;
}

.floating-cursor {
    right: 20%;
    top: 40%;
    animation: 28s hovering-1 infinite ease-in-out;
}

.floating-cursor-2 {
    left: 15%;
    top: 55%;
    animation: 33s hovering-2 infinite ease-in-out;
}

.floating-cursor-3 {
    right: 40%;
    top: 65%;
    animation: 41s hovering-3 infinite ease-in-out;
}

.floating-cursor .cursor-name {
    background-color: #0080FE;
}

.floating-cursor-2 .cursor-name {
    background-color: #8B5CF6;
}

.floating-cursor-3 .cursor-name {
    background-color: #F59E0B;
}

.cursor-comment {
    position: absolute;
    top: -45px;
    left: 25px;
    background-color: rgba(0, 0, 0, 0.9);
    color: #fff;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 12px;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
}

.cursor-comment.show {
    opacity: 1;
    transform: translateY(0);
}

.cursor-comment::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 15px;
    width: 0;
    height: 0;
    border-left: 6px solid transparent;
    border-right: 6px solid transparent;
    border-top: 6px solid rgba(0, 0, 0, 0.9);
}

@keyframes hovering-1 {
    0% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
    8% { transform: translate3d(-45px, 25px, 0px) rotate(2deg); }
    16% { transform: translate3d(70px, -30px, 0px) rotate(-1deg); }
    24% { transform: translate3d(-25px, 45px, 0px) rotate(3deg); }
    32% { transform: translate3d(90px, 10px, 0px) rotate(0deg); }
    40% { transform: translate3d(-70px, -35px, 0px) rotate(-2deg); }
    48% { transform: translate3d(30px, 60px, 0px) rotate(1deg); }
    56% { transform: translate3d(-50px, 20px, 0px) rotate(-1deg); }
    64% { transform: translate3d(80px, -45px, 0px) rotate(2deg); }
    72% { transform: translate3d(-35px, 30px, 0px) rotate(0deg); }
    80% { transform: translate3d(55px, -15px, 0px) rotate(-3deg); }
    88% { transform: translate3d(-20px, 50px, 0px) rotate(1deg); }
    96% { transform: translate3d(15px, -25px, 0px) rotate(0deg); }
    100% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
}

@keyframes hovering-2 {
    0% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
    12% { transform: translate3d(85px, -40px, 0px) rotate(-2deg); }
    18% { transform: translate3d(-60px, 35px, 0px) rotate(1deg); }
    28% { transform: translate3d(45px, 55px, 0px) rotate(3deg); }
    36% { transform: translate3d(-80px, -20px, 0px) rotate(-1deg); }
    44% { transform: translate3d(25px, 70px, 0px) rotate(2deg); }
    52% { transform: translate3d(-45px, -50px, 0px) rotate(0deg); }
    60% { transform: translate3d(95px, 15px, 0px) rotate(-3deg); }
    68% { transform: translate3d(-30px, 40px, 0px) rotate(1deg); }
    76% { transform: translate3d(65px, -25px, 0px) rotate(2deg); }
    84% { transform: translate3d(-55px, 60px, 0px) rotate(-1deg); }
    92% { transform: translate3d(40px, -35px, 0px) rotate(0deg); }
    100% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
}

@keyframes hovering-3 {
    0% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
    9% { transform: translate3d(-75px, 45px, 0px) rotate(1deg); }
    17% { transform: translate3d(50px, -55px, 0px) rotate(-2deg); }
    26% { transform: translate3d(-40px, 30px, 0px) rotate(3deg); }
    34% { transform: translate3d(100px, 20px, 0px) rotate(0deg); }
    43% { transform: translate3d(-85px, -30px, 0px) rotate(-1deg); }
    51% { transform: translate3d(35px, 65px, 0px) rotate(2deg); }
    60% { transform: translate3d(-55px, -40px, 0px) rotate(-3deg); }
    68% { transform: translate3d(80px, 50px, 0px) rotate(1deg); }
    77% { transform: translate3d(-25px, 10px, 0px) rotate(0deg); }
    85% { transform: translate3d(60px, -30px, 0px) rotate(-1deg); }
    93% { transform: translate3d(-70px, 35px, 0px) rotate(2deg); }
    100% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
}

@media (max-width: 768px) {
    .floating-cursor, .floating-cursor-2, .floating-cursor-3 {
        display: none;
    }
    
    .cursor-comment {
        display: none !important;
    }
}

/* Problem Section */
.problem {
    background-color: #151515;
    padding: var(--spacing-xxl) 0;
}

.problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
}

.problem-card {
    background: linear-gradient(135deg, 
        rgba(255, 255, 255, 0.06) 0%, 
        rgba(255, 255, 255, 0.02) 100%);
    padding: var(--spacing-lg);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s ease;
    height: 100%;
    position: relative;
}

.problem-card:hover {
    transform: translateY(-2px);
    background: linear-gradient(135deg, 
        rgba(255, 255, 255, 0.08) 0%, 
        rgba(255, 255, 255, 0.03) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}

.problem-icon {
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--color-white);
    transition: all 0.3s ease;
}

.problem-card:hover .problem-icon {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.problem-icon :global(svg) {
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
}

.problem-card:hover .problem-icon :global(svg) {
    transform: scale(1.05);
}

.problem-card h3 {
    color: var(--color-white);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    line-height: 1.3;
    transition: color 0.3s ease;
}

.problem-card p {
    color: var(--color-text-light);
    line-height: 1.6;
    font-size: 0.95rem;
    transition: color 0.3s ease;
}

.problem-card:hover p {
    color: rgba(255, 255, 255, 0.8);
}

/* How it works Section */
.how-it-works {
    background-color: var(--color-background);
    padding: var(--spacing-xxl) 0;
}

.steps-vertical {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-xl) 0;
}

.step-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: var(--spacing-xxl);
    position: relative;
}

.step-item:last-child {
    margin-bottom: 0;
}

.step-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
}

.step-number {
    background: linear-gradient(135deg, var(--color-highlight), rgba(255, 255, 255, 0.8));
    color: var(--color-background);
    font-weight: 800;
    font-size: 1.5rem;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2);
    z-index: 2;
    position: relative;
}

.step-connector {
    width: 2px;
    height: 80px;
    background: linear-gradient(to bottom, 
        rgba(255, 255, 255, 1) 0%, 
        rgba(255, 255, 255, 0) 100%);
    margin-top: var(--spacing-md);
}

.step-content {
    width: 100%;
    max-width: 600px;
    background-color: var(--color-card-bg);
    padding: var(--spacing-lg);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: var(--transition);
    position: relative;
    margin-top: var(--spacing-md);
}

.step-content:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.step-content h3 {
    color: var(--color-white);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
    font-weight: 700;
}

.step-content p {
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
}

.step-demo {
    margin-top: var(--spacing-md);
    padding: var(--spacing-md);
    background-color: rgba(255, 255, 255, 0.02);
    border-radius: var(--border-radius);
    border: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
}

.dropdown-mockup {
    position: relative;
    width: 100%;
}

.dropdown-menu {
    background: linear-gradient(135deg, 
        rgba(0, 0, 0, 0.95) 0%, 
        rgba(20, 20, 20, 0.9) 100%);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
    backdrop-filter: blur(20px);
    overflow: hidden;
    box-shadow: 
        0 8px 32px rgba(0, 0, 0, 0.6),
        0 4px 16px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.dropdown-item {
    padding: 16px 20px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    font-weight: 500;
    cursor: default;
    transition: all 0.3s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    text-align: left;
    position: relative;
}

.dropdown-item:last-child {
    border-bottom: none;
}

.dropdown-item:first-child {
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
}

.dropdown-item:last-child {
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
}

.dropdown-item.selected {
    background: linear-gradient(135deg, 
        rgba(255, 255, 255, 0.15) 0%, 
        rgba(255, 255, 255, 0.08) 100%);
    color: #ffffff;
    font-weight: 600;
    box-shadow: 
        inset 0 1px 0 rgba(255, 255, 255, 0.2),
        0 2px 8px rgba(0, 0, 0, 0.3);
}

.dropdown-item.animate-selection {
    animation: selectItem 0.5s ease-out forwards;
}

@keyframes selectItem {
    0% {
        background: transparent;
        color: rgba(255, 255, 255, 0.8);
        transform: translateX(0);
    }
    50% {
        transform: translateX(4px);
    }
    100% {
        background: linear-gradient(135deg, 
            rgba(255, 255, 255, 0.15) 0%, 
            rgba(255, 255, 255, 0.08) 100%);
        color: #ffffff;
        transform: translateX(0);
    }
}



.static-cursor {
    position: absolute;
    bottom: 10px;
    right: 80px;
    z-index: 2;
    pointer-events: none;
}

.static-cursor-name {
    padding: 2px 6px;
    color: #FFF;
    font-size: 11px;
    display: inline-block;
    position: absolute;
    top: 24px;
    left: 20px;
    border-radius: 4px;
    font-weight: 500;
    white-space: nowrap;
    background-color: #0080FE;
}

/* Use Cases Section */
.use-cases {
    background: linear-gradient(135deg, #151515 0%, #0f0f0f 100%);
    padding: var(--spacing-xxl) 0;
    position: relative;
    overflow: hidden;
}

.use-cases::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.02) 0%, transparent 70%);
    pointer-events: none;
}

.use-cases-content {
    position: relative;
    z-index: 1;
}

.use-cases h2 {
    color: var(--color-white);
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: var(--spacing-xl);
    text-align: center;
    line-height: 1.2;
}

.space-mono {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    letter-spacing: 0.5px;
}

.use-case-cards {
    display: flex;
    gap: var(--spacing-lg);
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: var(--spacing-md) 0;
    padding-left: var(--spacing-lg);
    padding-right: var(--spacing-lg);
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
}

.use-case-cards::-webkit-scrollbar {
    display: none;
}

.use-case-cards {
    -ms-overflow-style: none;
    scrollbar-width: none;
}

.use-case-card {
    background: linear-gradient(135deg, 
        rgba(255, 255, 255, 0.06) 0%, 
        rgba(255, 255, 255, 0.02) 100%);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: var(--spacing-lg);
    min-width: 400px;
    max-width: 400px;
    position: relative;
    backdrop-filter: blur(20px);
    transition: all 0.3s ease;
}

.use-case-card:hover {
    transform: translateY(-4px);
    background: linear-gradient(135deg, 
        rgba(255, 255, 255, 0.08) 0%, 
        rgba(255, 255, 255, 0.03) 100%);
    border: 1px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
}

.channel-tag {
    position: absolute;
    top: var(--spacing-md);
    right: var(--spacing-md);
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-white);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
}

.use-case-card p {
    color: var(--color-white);
    font-size: 1.5rem;
    line-height: 1.4;
    font-weight: 600;
    margin: 0;
    padding-top: var(--spacing-lg);
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.content-text {
    color: var(--color-white);
    font-size: 0.875rem;
    margin-bottom: var(--spacing-sm);
    font-style: italic;
}

.highlighted-text {
    background: var(--color-white);
    color: var(--color-background);
    font-size: 1rem;
    line-height: 1.5;
    padding: 4px 6px;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
    display: inline;
}

.step2-badge {
    position: absolute;
    top: -8px;
    right: var(--spacing-md);
    margin: 0;
}

.reaction-preview {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
}

.reaction {
    padding: var(--spacing-md);
    border-radius: 8px;
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: all 0.2s ease;
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
}

.suggestion-checkbox {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 3px;
    background-color: transparent;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
    transition: all 0.3s ease;
}

.suggestion-checkbox :global(svg) {
    width: 12px;
    height: 12px;
    color: var(--color-background);
    opacity: 0;
    transform: scale(0);
    transition: all 0.3s ease;
}

.suggestion-checkbox.animate {
    animation: checkboxFill 1.5s ease-out forwards;
}

.suggestion-checkbox.animate :global(svg) {
    animation: checkAppear 1.5s ease-out forwards;
}

@keyframes checkboxFill {
    0% {
        background-color: transparent;
        border-color: rgba(255, 255, 255, 0.3);
    }
    60% {
        background-color: transparent;
        border-color: rgba(255, 255, 255, 0.3);
    }
    70% {
        background-color: var(--color-white);
        border-color: var(--color-white);
    }
    100% {
        background-color: var(--color-white);
        border-color: var(--color-white);
    }
}

@keyframes checkAppear {
    0% {
        opacity: 0;
        transform: scale(0);
    }
    60% {
        opacity: 0;
        transform: scale(0);
    }
    70% {
        opacity: 1;
        transform: scale(1.2);
    }
    100% {
        opacity: 1;
        transform: scale(1);
    }
}

.suggestion-content {
    flex: 1;
}

.suggestion-header {
    color: var(--color-white);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 4px;
    line-height: 1.3;
}

.suggestion-insight {
    color: var(--color-text-light);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.4;
    font-style: italic;
}



@media (max-width: 768px) {
    .hero h1 {
        font-size: 2.5rem;
    }
    
    .hero-description {
        font-size: 1.1rem;
    }
    
    .cta-buttons {
        flex-direction: column;
        align-items: center;
    }
    
    .steps-vertical {
        padding: var(--spacing-md) 0;
    }
    
    .step-item {
        margin-bottom: var(--spacing-xl);
    }
    
    .step-content {
        padding: var(--spacing-md);
    }
    
    .step-content h3 {
        font-size: 1.25rem;
    }
    
    .use-cases h2 {
        font-size: 2rem;
        margin-bottom: var(--spacing-lg);
    }
    
    .use-case-cards {
        padding-left: var(--spacing-md);
        padding-right: var(--spacing-md);
    }
    
    .use-case-card {
        min-width: 300px;
        max-width: 300px;
        padding: var(--spacing-md);
    }
    
    .use-case-card p {
        font-size: 1.25rem;
        line-height: 1.4;
        padding-top: var(--spacing-lg);
    }
    
    .channel-tag {
        top: var(--spacing-sm);
        right: var(--spacing-sm);
        padding: 3px 8px;
        font-size: 0.7rem;
    }
}

/* FAQ Section */
.faq {
    background-color: #151515;
}

.faq-container {
    max-width: 800px;
    margin: 0 auto;
}

.faq-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: var(--spacing-md);
}

.faq-question {
    position: relative;
    padding: var(--spacing-md) var(--spacing-md) var(--spacing-md) 0;
    cursor: pointer;
    font-weight: 500;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    color: inherit;
    font-size: 1.5rem;
    font-family: var(--font-heading);
    margin-bottom: var(--spacing-sm);
    line-height: 1.2;
}

.question-text {
    flex: 1;
}

.faq-question::after {
    content: '+';
    font-size: 1.5rem;
    color: var(--color-primary);
    transition: transform 0.3s ease;
}

.faq-item.active .faq-question::after {
    content: '−';
    transform: rotate(0deg);
}

.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding: 0 var(--spacing-md) 0 0;
}

.faq-item.active .faq-answer {
    max-height: 500px;
    padding: 0 var(--spacing-md) var(--spacing-md) 0;
}

/* Empathy Section */
.empathy-section {
    background-color: var(--color-background);
    padding: var(--spacing-xxl) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
}

.empathy-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
}

.empathy-content h2 {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-xl);
    line-height: 1.2;
    color: var(--color-white);
}

.power-emphasis {
    font-size: 3rem;
    font-weight: 800;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0.05) 100%);
    padding: 8px 20px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    letter-spacing: -0.5px;
    position: relative;
    display: inline-block;
    backdrop-filter: blur(15px);
    box-shadow: 
        0 8px 32px rgba(255, 255, 255, 0.1),
        0 0 20px rgba(255, 255, 255, 0.05),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
}

.lead-text {
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-text-light);
    max-width: 800px;
    margin: 0 auto;
}

/* Empathy Cursor */
.empathy-cursor {
    position: absolute;
    right: 25%;
    top: 25%;
    z-index: 10;
    pointer-events: none;
    animation: 35s empathy-hovering infinite ease-in-out;
}

.empathy-cursor .cursor-name {
    background-color: #F59E0B;
}

@keyframes empathy-hovering {
    0% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
    12% { transform: translate3d(-60px, 15px, 0px) rotate(0.5deg); }
    25% { transform: translate3d(80px, -20px, 0px) rotate(-0.5deg); }
    37% { transform: translate3d(-40px, 35px, 0px) rotate(1deg); }
    50% { transform: translate3d(70px, 25px, 0px) rotate(-0.5deg); }
    62% { transform: translate3d(-70px, -10px, 0px) rotate(0.5deg); }
    75% { transform: translate3d(50px, 40px, 0px) rotate(-1deg); }
    87% { transform: translate3d(-30px, 20px, 0px) rotate(0.5deg); }
    100% { transform: translate3d(0px, 0px, 0px) rotate(0deg); }
}

@media (max-width: 768px) {
    .empathy-cursor {
        display: none;
    }
    
    .empathy-section {
        padding: var(--spacing-xl) 0;
    }
    
    .empathy-content h2 {
        font-size: 2rem;
    }
    
    .power-emphasis {
        font-size: 2.25rem;
        padding: 6px 16px;
    }
    
    .lead-text {
        font-size: 1.25rem;
    }
}
</style>

<script>
  // Rotating text functionality
  document.addEventListener('DOMContentLoaded', function() {
    const rotatingText = document.querySelector('.rotating-text') as HTMLElement;
    if (rotatingText) {
      const words = ['sending', 'posting', 'sharing'];
      let currentIndex = 0;
      
      function rotateText() {
        currentIndex = (currentIndex + 1) % words.length;
        rotatingText.textContent = words[currentIndex];
      }
      
      // Change word every 2 seconds
      setInterval(rotateText, 2000);
    }
    
    // Auto-scroll use case cards with infinite scroll
    const useCaseCards = document.querySelector('.use-case-cards') as HTMLElement;
    if (useCaseCards) {
      let currentCardIndex = 0;
      const totalCards = useCaseCards.children.length;
      const originalCards = totalCards / 2; // Half are duplicates
      
      function autoScroll() {
        currentCardIndex++;
        
        // Reset to beginning seamlessly when we reach the duplicate section
        if (currentCardIndex >= originalCards) {
          // Instantly reset to the beginning (no animation)
          useCaseCards.scrollTo({
            left: 0,
            behavior: 'instant'
          });
          currentCardIndex = 1; // Start from the second card to continue smoothly
        }
        
        // Get actual card dimensions from DOM
        const firstCard = useCaseCards.children[0] as HTMLElement;
        if (!firstCard) return;
        
        const cardRect = firstCard.getBoundingClientRect();
        const containerRect = useCaseCards.getBoundingClientRect();
        const cardWidth = cardRect.width;
        
        // Get the computed gap between cards
        const computedStyle = window.getComputedStyle(useCaseCards);
        const gap = parseFloat(computedStyle.gap) || 16; // Default to 16px if gap not found
        
        const cardWithGap = cardWidth + gap;
        const containerWidth = containerRect.width;
        
        // Calculate scroll position to center the card in viewport
        const targetCardPosition = currentCardIndex * cardWithGap;
        const scrollPosition = targetCardPosition - (containerWidth / 2) + (cardWidth / 2);
        
        // Clamp to prevent overflow
        const maxScroll = useCaseCards.scrollWidth - containerWidth;
        const clampedPosition = Math.max(0, Math.min(scrollPosition, maxScroll));
        
        useCaseCards.scrollTo({
          left: clampedPosition,
          behavior: 'smooth'
        });
      }
      
      // Auto-scroll every 4 seconds
      setInterval(autoScroll, 4000);
    }
    
    // FAQ functionality
    const faqContainer = document.getElementById('faq');
    if (faqContainer) {
      const faqItems = faqContainer.querySelectorAll('.faq-item');
      if (faqItems.length > 0) {
        faqItems.forEach(item => {
          const question = item.querySelector('.faq-question');
          if (!question) return;

          question.setAttribute('aria-expanded', 'false');

          const answer = item.querySelector('.faq-answer');
          if (!answer) return;
          
          // Associate question with answer for screen readers
          const answerId = `faq-answer-${Math.random().toString(36).substring(2, 15)}`;
          answer.setAttribute('id', answerId);
          question.setAttribute('aria-controls', answerId);
          answer.setAttribute('aria-hidden', 'true');

          const clickHandler = () => {
              const expanded = item.classList.contains('active');
              question.setAttribute('aria-expanded', String(!expanded));
              answer.setAttribute('aria-hidden', String(expanded));
              item.classList.toggle('active');

              // Close other items (accordion style)
              faqItems.forEach(otherItem => {
                if (otherItem !== item && otherItem.classList.contains('active')) {
                  otherItem.classList.remove('active');
                  const otherQuestion = otherItem.querySelector('.faq-question');
                  const otherAnswer = otherItem.querySelector('.faq-answer');
                  if(otherQuestion) otherQuestion.setAttribute('aria-expanded', 'false');
                  if(otherAnswer) otherAnswer.setAttribute('aria-hidden', 'true');
                }
              });
          };

          question.addEventListener('click', clickHandler);
        });
      }
    }
    
    // Floating cursors with random comments
    const startupComments = [
      "Obviously we're building this already",
      "This is just ChatGPT with extra steps",
      "We did this at my last unicorn",
      "Cool but where's the blockchain?",
      "This won't scale past 10k users",
      "My intern could build this in a weekend",
      "Why didn't they just use our API?",
      "We're disrupting this space harder",
      "This is so 2023",
      "Our solution is way more elegant",
      "They clearly don't understand PMF",
      "This is what we pivoted from",
      "We should just acquihire them",
      "Cute MVP but not enterprise-ready",
      "Our Series A pitch deck had this"
    ];
    
    const gregComments = [
      "I need to update my spreadsheet",
      "This goes in Q3 expenses",
      "Is this tax deductible?",
      "We already have email for this",
      "Can't we just use what we have?",
      "I'll need to see the receipt",
      "This needs approval from Janet",
      "What's the cancellation policy?",
      "We're over budget this quarter",
      "Did you submit the expense report?",
      "This looks like marketing spend",
      "Are there any hidden fees?",
      "We should table this until next year",
      "I'll add it to the review queue",
      "Does this integrate with QuickBooks?"
    ];
    
    const genzComments = [
      "This is actually genius ngl",
      "Virtual audiences hit different",
      "No cap this slaps",
      "Why didn't I think of this",
      "This would save my content",
      "My posts need this fr",
      "Audience reactions = everything",
      "Testing before posting? Valid",
      "This is so necessary bestie",
      "My content flops need this",
      "Actually revolutionary",
      "This could change the game",
      "Need this for my brand",
      "Audience insight is chef's kiss",
      "Why am I not using this yet"
    ];
    
    const empathyComments = [
      "Wait what's perspective taking?",
      "So like... I just think about other people?",
      "This sounds exhausting tbh",
      "I don't get it do I pretend to be them?",
      "My brain hurts reading this"
    ];
    
    const founderFollowUpComments = [
      "This sounds too desperate",
      "What's the business impact here?",
      "This guy's got no business sense",
      "I don't want to be followed up on",
    ];
    
              function showRandomComment(commentId: string) {
       const commentElement = document.getElementById(commentId);
       if (!commentElement) return;
       
       let comments;
       if (commentId === 'comment-1') comments = startupComments;
       else if (commentId === 'comment-2') comments = gregComments;
       else if (commentId === 'comment-3') comments = genzComments;
       else if (commentId === 'greg-step2-comment') comments = founderFollowUpComments;
       else if (commentId === 'empathy-comment') comments = empathyComments;
       else return;
       
       const randomComment = comments[Math.floor(Math.random() * comments.length)];
       commentElement.textContent = randomComment;
       commentElement.classList.add('show');
       
       setTimeout(() => {
         commentElement.classList.remove('show');
       }, 3000);
     }
    
    // Show random comments at intervals
    setInterval(() => showRandomComment('comment-1'), 8000);
    setInterval(() => showRandomComment('comment-2'), 12000);
    setInterval(() => showRandomComment('comment-3'), 15000);
    setInterval(() => showRandomComment('greg-step2-comment'), 5000);
    setInterval(() => showRandomComment('empathy-comment'), 10000);
    
    // Initial comments after page load
    setTimeout(() => showRandomComment('comment-1'), 3000);
    setTimeout(() => showRandomComment('comment-2'), 6000);
    setTimeout(() => showRandomComment('comment-3'), 9000);
    setTimeout(() => showRandomComment('greg-step2-comment'), 2000);
    setTimeout(() => showRandomComment('empathy-comment'), 4000);
    
    // Checkbox animation on scroll into view
    const checkboxElement = document.querySelector('.suggestion-checkbox') as HTMLElement;
    if (checkboxElement) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !entry.target.classList.contains('animate')) {
            entry.target.classList.add('animate');
          }
        });
      }, {
        threshold: 0.5 // Trigger when 50% of the element is visible
      });
      
      observer.observe(checkboxElement);
    }
    
    // Dropdown animation on scroll into view
    const dropdownElement = document.getElementById('audience-dropdown');
    if (dropdownElement) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !entry.target.classList.contains('animated')) {
            entry.target.classList.add('animated');
            
            // Animate the selection after a short delay
            setTimeout(() => {
              const startupItem = document.getElementById('startup-founders-item');
              
              if (startupItem) {
                // Add selection animation to the item
                startupItem.classList.add('animate-selection');
                
                // After animation completes, add the final selected state
                setTimeout(() => {
                  startupItem.classList.add('selected');
                }, 500);
              }
            }, 500);
          }
        });
      }, {
        threshold: 0.4 // Trigger when 40% of the element is visible
      });
      
      observer.observe(dropdownElement);
    }
  });
</script>
