---
// INSTRUCTIONS:
// 1. Save this as a new file in src/pages/ with the same name as your content file
//    Example: If your content is 'linkedin-tool.md', save this as 'linkedin-tool.astro'
// 2. Update the entry.id in the find() function to match your content filename
// 3. Add/remove component imports as needed based on what sections you included

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Import only the components you're using
import LandingPageHero from '../../components/LandingPageHero.astro';
import FeaturesSection from '../../components/FeaturesSection.astro';
import FAQsSection from '../../components/FAQsSection.astro';
import FinalCTASection from '../../components/FinalCTASection.astro';

// Fetch this specific page content - CHANGE 'landing-page-template.md' TO YOUR FILENAME
const homepageEntries = await getCollection('homepage');
const entry = homepageEntries.find(entry => entry.id === 'landing-page-template.md');

// Error handling if content file not found
if (!entry) {
  return new Response('Content not found', { status: 404 });
}
---

<BaseLayout title={entry.data.pageTitle} description={entry.data.pageDescription} entry={entry}>
  {/* Only renders components that exist in your content file */}
  {entry.data.landingPageHero && (<LandingPageHero {...entry.data.landingPageHero} />)}
  {entry.data.featuresSection && (<FeaturesSection {...entry.data.featuresSection} />)}
  {entry.data.faqSection && (<FAQsSection {...entry.data.faqSection} />)}
  {entry.data.finalCtaSection && (<FinalCTASection {...entry.data.finalCtaSection} />)}
  
  {/* Add any other components here that you included in your content file */}
</BaseLayout> 
