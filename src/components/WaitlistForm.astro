---
// Simple waitlist form component
---

<form id="waitlist-form" class="waitlist-form">
  <div class="form-group">
    <div class="form-inputs">
      <input
        type="text"
        name="first_name"
        placeholder="First name"
        required
        class="name-input"
      />
      <input
        type="text"
        name="company"
        placeholder="Company"
        class="company-input"
      />
      <input
        type="email"
        name="email"
        placeholder="Email"
        required
        class="email-input"
      />
    </div>

    <button type="submit" class="btn btn-primary">
      <span class="btn-text">Join Beta</span>
      <span class="btn-loading" style="display: none;">Joining...</span>
    </button>
  </div>
  <div class="form-message" style="display: none;"></div>
</form>
<input
  type="text"
  id="website-url"
  style="display: none"
  tabindex="-1"
  autocomplete="off"
/>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("waitlist-form");
    if (!form) return;

    // Let forms.js capture the data — prevent native GET submission
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const formEl = form as HTMLFormElement;
      const formGroup = formEl.querySelector(".form-group") as HTMLElement;
      const message = formEl.querySelector(".form-message") as HTMLDivElement;

      // Show success after a short delay to let forms.js process
      setTimeout(() => {
        formGroup.style.display = "none";
        message.textContent = "Thanks for joining! We'll be in touch soon.";
        message.className = "form-message success";
        message.style.display = "block";
      }, 500);
    });
  });
</script>

<style>
  .waitlist-form {
    max-width: 320px;
    margin: 0 auto;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
  }

  .form-inputs {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .name-input,
  .company-input,
  .email-input {
    flex: 1;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-white);
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .name-input::placeholder,
  .company-input::placeholder,
  .email-input::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }

  .name-input:focus,
  .company-input:focus,
  .email-input:focus {
    outline: none;
    border-color: var(--color-white);
    background: rgba(255, 255, 255, 0.15);
  }

  .btn-primary {
    padding: var(--spacing-sm) var(--spacing-lg);
    background: var(--color-white);
    color: var(--color-background);
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
  }

  .btn-primary:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
  }

  .btn-primary:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .form-message {
    text-align: center;
    padding: var(--spacing-sm);
    border-radius: 4px;
    font-size: 0.9rem;
    margin-top: var(--spacing-sm);
  }

  .form-message.success {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .form-message.error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .form-inputs {
      flex-direction: column;
    }

    .submit-btn {
      width: 100%;
      min-width: unset;
    }
  }
</style>
