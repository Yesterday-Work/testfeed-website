---
// Simple waitlist form component
---

<form id="waitlist-form" class="waitlist-form">
  <div class="form-group">
    <input 
      type="email" 
      name="email" 
      placeholder="Enter your email" 
      required 
      class="email-input"
    />

    <input 
      type="text" 
      name="website" 
      style="display: none" 
      tabindex="-1" 
      autocomplete="off"
    />
    <button type="submit" class="btn btn-primary pulse">
      <span class="btn-text">JOIN WAITLIST</span>
      <span class="btn-loading" style="display: none;">JOINING...</span>
    </button>
  </div>
  <div class="form-message" style="display: none;"></div>
</form>

<script>
  // @ts-ignore - Customer.io global variable
  declare const cioanalytics: any;
  
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('waitlist-form');
    if (!form) return;
    
    form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const form = e.target as HTMLFormElement;
    const email = (form.email as HTMLInputElement).value;
    const honeypot = (form.website as HTMLInputElement).value;
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const btnText = button.querySelector('.btn-text') as HTMLSpanElement;
    const btnLoading = button.querySelector('.btn-loading') as HTMLSpanElement;
    const message = form.querySelector('.form-message') as HTMLDivElement;
    
    // Show loading state
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';
    button.disabled = true;
    
    if (honeypot) {
      setTimeout(() => {
        message.textContent = 'Thanks for joining!';
        message.className = 'form-message success';
        message.style.display = 'block';
        
        form.reset();
        btnText.style.display = 'inline';
        btnLoading.style.display = 'none';
        button.disabled = false;
      }, 1000);
      return;
    }
    
    // Basic email validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      message.textContent = 'Please enter a valid email address';
      message.className = 'form-message error';
      message.style.display = 'block';
      
      // Reset loading state
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
      button.disabled = false;
      return;
    }
    
    try {
      // Check if Customer.io is loaded
      if (typeof cioanalytics === 'undefined') {
        throw new Error('Customer.io not loaded');
      }
      
      // Send to Customer.io
      cioanalytics.identify(email, { 
        email: email,
        joined_waitlist_at: new Date().toISOString(),
        source: 'website_waitlist'
      });
      
      cioanalytics.track('joined_waitlist', {
        source: 'hero_cta',
        page: window.location.pathname
      });
      
      // Hide the form and show success message
      (form.querySelector('.form-group') as HTMLElement).style.display = 'none';
      message.textContent = 'Thanks for joining! We\'ll be in touch soon.';
      message.className = 'form-message success';
      message.style.display = 'block';
      
    } catch (error) {
      console.error('Error submitting to Customer.io:', error);
      message.textContent = 'Something went wrong. Please try again.';
      message.className = 'form-message error';
      message.style.display = 'block';
      
      // Reset loading state only on error
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
      button.disabled = false;
    }
    });
  });
</script>

<style>
  .waitlist-form {
    max-width: 400px;
    margin: 0 auto;
  }
  
  .form-group {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
  }
  
  .email-input {
    flex: 2;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-white);
    font-size: 1rem;
    transition: all 0.2s ease;
  }
  
  .email-input::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }
  
  .email-input:focus {
    outline: none;
    border-color: var(--color-white);
    background: rgba(255, 255, 255, 0.15);
  }
  
  .submit-btn {
    padding: var(--spacing-sm) var(--spacing-lg);
    background: var(--color-white);
    color: var(--color-background);
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    min-width: 120px;
  }
  
  .submit-btn:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
  }
  
  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }
  
  .form-message {
    text-align: center;
    padding: var(--spacing-sm);
    border-radius: 4px;
    font-size: 0.9rem;
    margin-top: var(--spacing-sm);
  }
  
  .form-message.success {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
  
  .form-message.error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
  
  /* Mobile responsive */
  @media (max-width: 768px) {
    .form-group {
      flex-direction: column;
    }
    
    .submit-btn {
      width: 100%;
      min-width: unset;
    }
  }
</style> 
