---
// This component doesn't need any props since it's static
// It's purely visual to match LinkedIn's UI
---

<div class="post-actions">
  <button class="action-button like-button">
    <span class="action-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path>
      </svg>
    </span>
    <span class="action-text">Like</span>
  </button>
  
  <button class="action-button comment-button">
    <span class="action-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </span>
    <span class="action-text">Comment</span>
  </button>
  
  <button class="action-button repost-button">
    <span class="action-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 1l4 4-4 4"></path>
        <path d="M3 11V9a4 4 0 0 1 4-4h14"></path>
        <path d="M7 23l-4-4 4-4"></path>
        <path d="M21 13v2a4 4 0 0 1-4 4H3"></path>
      </svg>
    </span>
    <span class="action-text">Repost</span>
  </button>
  
  <button class="action-button send-button">
    <span class="action-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </span>
    <span class="action-text">Send</span>
  </button>
</div>

<style>
  .post-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0 0;
    margin-top: 4px;
  }
  
  .action-button {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    border-radius: 4px;
    color: rgba(0, 0, 0, 0.6);
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 8px;
    min-width: 64px;
    flex: 1;
  }
  
  .action-button:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }
  
  .action-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 4px;
  }
  
  .action-icon svg {
    width: 18px;
    height: 18px;
    stroke: rgba(0, 0, 0, 0.6);
  }
  
  .action-text {
    font-size: 14px;
    white-space: nowrap;
    font-weight: 600;
  }
</style> 
