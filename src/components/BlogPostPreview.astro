---
// Define the props that this component accepts
export interface Props {
  post: {
    slug: string;
    data: {
      pageTitle: string;
      articleTitle?: string;
      excerpt: string;
      publishDate: Date;
      author: string;
      featuredImage?: string;
      tags?: string[];
    }
  }
}

const { post } = Astro.props;

// Format the date
const formattedDate = new Date(post.data.publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Use articleTitle if available, otherwise fallback to pageTitle (without suffix)
const displayTitle = post.data.articleTitle 
  ? post.data.articleTitle
  : post.data.pageTitle.split(' | ')[0];
---

<div class="blog-card">
  <div class="blog-card-image">
    {post.data.featuredImage ? (
      <img 
        src={post.data.featuredImage} 
        alt={post.data.pageTitle} 
        loading="lazy" 
      />
    ) : (
      <div class="placeholder-image">
        <i data-lucide="file-text"></i>
      </div>
    )}
  </div>
  <div class="blog-card-content">
    <div class="blog-meta">
      <span class="date">{formattedDate}</span>
      {post.data.tags && post.data.tags.length > 0 && (
        <span class="tags">
          {post.data.tags[0]}
        </span>
      )}
    </div>
    <h2><a href={`/blog/${post.slug}`}>{displayTitle}</a></h2>
    <p class="excerpt">{post.data.excerpt}</p>
    <div class="blog-footer">
      <span class="author">By {post.data.author}</span>
      <a href={`/blog/${post.slug}`} class="read-more">Read article <i data-lucide="arrow-right"></i></a>
    </div>
  </div>
</div>

<style>
.blog-card {
  background-color: var(--color-card-bg);
  border-radius: var(--border-radius);
  overflow: hidden;
  transition: var(--transition);
  border: 1px solid rgba(255, 255, 255, 0.1);
  height: 100%;
  display: flex;
  flex-direction: column;
}

.blog-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-lg);
  border-color: rgba(255, 255, 255, 0.2);
}

.blog-card-image {
  height: 200px;
  overflow: hidden;
}

.blog-card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.blog-card:hover .blog-card-image img {
  transform: scale(1.05);
}

.placeholder-image {
  width: 100%;
  height: 100%;
  background-color: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-light);
}

.placeholder-image i {
  width: 40px;
  height: 40px;
}

.blog-card-content {
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  flex: 1;
}

.blog-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
  font-size: 0.9rem;
}

.date, .tags {
  color: var(--color-text-light);
}

.tags {
  background-color: rgba(255, 255, 255, 0.1);
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 0.8rem;
}

.blog-card h2 {
  font-size: 1.4rem;
  margin-bottom: var(--spacing-sm);
  text-align: left;
}

.blog-card h2 a {
  color: var(--color-white);
  text-decoration: none;
}

.excerpt {
  color: var(--color-text-light);
  margin-bottom: var(--spacing-md);
  font-size: 0.95rem;
  flex-grow: 1;
}

.blog-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  padding-top: var(--spacing-sm);
}

.author {
  font-size: 0.9rem;
  color: var(--color-text-light);
}

.read-more {
  font-size: 0.9rem;
  display: flex;
  align-items: center;
  gap: 5px;
  color: var(--color-primary);
  font-weight: 600;
}

.read-more i {
  width: 16px;
  height: 16px;
  transition: transform 0.3s ease;
}

.read-more:hover i {
  transform: translateX(3px);
}

@media (max-width: 768px) {    
  .blog-card-image {
    height: 180px;
  }
} 
</style>
