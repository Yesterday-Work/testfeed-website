---
export interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      articleTitle: string;
      excerpt: string;
      publishDate: Date;
      author: string;
      featuredImage?: string;
      tags?: string[];
      minutesRead?: number;
    };
  };
}

const { post } = Astro.props;
---

<a class="rcard" href={`/blog/${post.slug}/`}>
  <div class="thumb">
    {post.data.featuredImage ? (
      <img
        src={post.data.featuredImage}
        alt={post.data.articleTitle}
        width="400"
        height="168"
        loading="lazy"
        decoding="async"
        style="width:100%;height:100%;object-fit:cover;display:block;"
      />
    ) : (
      <div class="thumb-placeholder"></div>
    )}
  </div>
  <div class="rc-body">
    {post.data.tags && post.data.tags[0] && (
      <p class="rc-cat">{post.data.tags[0]}</p>
    )}
    <h3>{post.data.articleTitle}</h3>
    <p class="rc-excerpt">{post.data.excerpt}</p>
    <div class="rc-foot">
      {post.data.minutesRead && <span>{post.data.minutesRead} min read</span>}
      <span class="go">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .rcard {
    background: #F8F5F1;
    border: 1px solid rgba(0,0,0,0.10);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    transition: transform 240ms cubic-bezier(0.22,1,0.36,1), box-shadow 240ms cubic-bezier(0.22,1,0.36,1);
  }
  .rcard:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 30px rgba(0,0,0,0.08);
  }
  .thumb {
    height: 168px;
    background: #F1EDE7;
    border-bottom: 1px solid rgba(0,0,0,0.10);
    overflow: hidden;
    flex-shrink: 0;
  }
  .thumb-placeholder {
    width: 100%;
    height: 100%;
    background: #E8E1DA;
  }
  .rc-body {
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .rc-cat {
    font-family: 'Inter', sans-serif;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #E6392E;
    margin: 0 0 10px;
  }
  .rcard h3 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 20px;
    line-height: 1.18;
    letter-spacing: -0.01em;
    color: #111111;
    margin: 0 0 10px;
  }
  .rc-excerpt {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: #5F5F5F;
    margin: 0 0 16px;
    flex: 1;
  }
  .rc-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    color: #5F5F5F;
  }
  .go {
    margin-left: auto;
    color: #E6392E;
    display: grid;
    place-items: center;
  }
</style>
