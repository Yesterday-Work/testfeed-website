---
export interface Props {
  title: string;
  author: string;
  publishDate: Date;
  featuredImage?: string;
  tags?: string[];
}

const { title, author, publishDate, featuredImage, tags } = Astro.props;

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<section class="blog-hero">
  <div class="container">
    <div class="hero-content">
      <h1>{title}</h1>
      <div class="meta-info">
        <span>By {author}</span>
        <span>&bull;</span>
        <span>{formattedDate}</span>
      </div>
      {tags && tags.length > 0 && (
        <div class="tags-container">
          {tags.map(tag => (
            <span class="tag-chip">{tag}</span>
          ))}
        </div>
      )}
    </div>
    {featuredImage && (
      <div class="hero-visual">
        <img src={featuredImage} alt={title} loading="lazy" />
      </div>
    )}
  </div>
</section>

<style>
.blog-hero {
  padding: 60px 0 48px;
  background: var(--bg-2);
  border-bottom: 1px solid var(--border-1, rgba(0,0,0,0.10));
}

.blog-hero .container {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 40px;
}

.hero-content h1 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--tf-ink);
  line-height: 1.1;
  max-width: 820px;
  margin: 0 auto 1rem;
}

.meta-info {
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--tf-stone);
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 0;
}

.tags-container {
  margin-top: 16px;
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
}

.tag-chip {
  background: var(--bg-1);
  color: var(--tf-stone);
  padding: 4px 14px;
  border-radius: 999px;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: var(--w-medium);
  border: 1px solid var(--border-1, rgba(0,0,0,0.12));
  transition: border-color 0.2s, color 0.2s;
}

.tag-chip:hover {
  border-color: var(--tf-red);
  color: var(--tf-red);
}

.hero-visual {
  width: 100%;
  max-width: 860px;
  margin: 0 auto;
}

.hero-visual img {
  width: 100%;
  height: auto;
  max-height: 460px;
  object-fit: cover;
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.10);
}

@media (max-width: 768px) {
  .blog-hero { padding: 40px 0 32px; }
  .hero-content h1 { font-size: 1.9rem; }
  .meta-info { font-size: 0.875rem; }
}
</style>
