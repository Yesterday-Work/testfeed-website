---
// This component represents the visual mockup and its animation logic.
// It currently doesn't need props as its content is static.
---
<div class="mockup-container">
  <!-- Post mockup -->
  <div class="post-mockup">
    <div class="post-avatar"></div>
    <div class="post-content">
      <div class="post-author">Sarah Johnson</div>
      <div class="post-meta">Just now • LinkedIn</div>
      <div class="post-text">
        <p>AI isn't replacing jobs - it's transforming them.</p>
        <p>Every technological shift in history has created more opportunities than it eliminated.</p>
        <p>The key is adaptation, not resistance.</p>
      </div>
    </div>

    <div class="testing-indicator">
      <div class="testing-pulse"></div>
      <p>Testing with 10,000 profiles</p>
    </div>
  </div>

  <!-- Results panel - slides in from bottom -->
  <div class="results-panel">
    <div class="results-header">
      <span class="testfeed-font">testfeed</span> results
    </div>

    <div class="metrics-list">
      <div class="metric">
        <div class="metric-name">Reach</div>
        <div class="metric-bar-container">
          <div class="metric-bar" id="reach-bar"></div>
        </div>
        <div class="metric-value"><span id="reach-value">0</span></div>
      </div>

      <div class="metric">
        <div class="metric-name">Engagement</div>
        <div class="metric-bar-container">
          <div class="metric-bar" id="engagement-bar"></div>
        </div>
        <div class="metric-value"><span id="engagement-value">0</span>%</div>
      </div>

      <div class="metric">
        <div class="metric-name">Sentiment</div>
        <div class="metric-bar-container sentiment">
          <div class="sentiment-section negative" id="sentiment-negative"></div>
          <div class="sentiment-section neutral" id="sentiment-neutral"></div>
          <div class="sentiment-section positive" id="sentiment-positive"></div>
        </div>
        <div class="metric-value">Positive</div>
      </div>
    </div>
  </div>
</div> 

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
    initializePostMockupAnimation();
});

// Initialize the animation for the PostMockup
function initializePostMockupAnimation() {
    const mockupContainer = document.querySelector('.mockup-container');
    if (!mockupContainer) return;
    
    // Start the animation when the component is in viewport
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                runAnimation();
                observer.unobserve(mockupContainer);
            }
        });
    }, { threshold: 0.3 });
    
    observer.observe(mockupContainer);
}

// Animation sequence function
function runAnimation() {
    // Initial state reset
    const testingIndicator = document.querySelector('.testing-indicator');
    const resultsPanel = document.querySelector('.results-panel');
    
    if (!testingIndicator || !resultsPanel) return;
    
    testingIndicator.classList.remove('active');
    resultsPanel.classList.remove('active');
    
    // Reset counters and bars - add null checks
    const reachValue = document.getElementById('reach-value');
    const engagementValue = document.getElementById('engagement-value');
    const reachBar = document.getElementById('reach-bar');
    const engagementBar = document.getElementById('engagement-bar');
    const sentimentNegative = document.getElementById('sentiment-negative');
    const sentimentNeutral = document.getElementById('sentiment-neutral');
    const sentimentPositive = document.getElementById('sentiment-positive');
    
    // Safe updates with null checks
    if (reachValue) reachValue.textContent = '0';
    if (engagementValue) engagementValue.textContent = '0';
    if (reachBar) reachBar.style.width = '0%';
    if (engagementBar) engagementBar.style.width = '0%';
    if (sentimentNegative) sentimentNegative.style.width = '0%';
    if (sentimentNeutral) sentimentNeutral.style.width = '0%';
    if (sentimentPositive) sentimentPositive.style.width = '0%';
    
    // Animation sequence
    setTimeout(() => {
        // Step 1: Show testing indicator
        testingIndicator.classList.add('active');
        
        // Step 2: Hide testing, show results
        setTimeout(() => {
            testingIndicator.classList.remove('active');
            
            setTimeout(() => {
                resultsPanel.classList.add('active');
                
                // Animate reach
                setTimeout(() => {
                    if (reachBar) reachBar.style.width = '78%';
                    animateCounter('reach-value', 10000, 1500);
                }, 300);
                
                // Animate engagement
                setTimeout(() => {
                    if (engagementBar) engagementBar.style.width = '84%';
                    animateCounter('engagement-value', 5.2, 1500, true);
                }, 600);
                
                // Animate sentiment
                setTimeout(() => {
                    if (sentimentNegative) sentimentNegative.style.width = '20%';
                    
                    setTimeout(() => {
                        if (sentimentNeutral) sentimentNeutral.style.width = '30%';
                        
                        setTimeout(() => {
                            if (sentimentPositive) sentimentPositive.style.width = '50%';
                        }, 200);
                    }, 200);
                }, 900);
            }, 400);
        }, 2500);
        
        // Reset and restart animation
        setTimeout(() => {
            runAnimation();
        }, 10000);
    }, 1000);
}

// Function to animate the counter
function animateCounter(elementId, targetValue, duration, isPercentage = false) {
    const element = document.getElementById(elementId);
    if (!element) return;
    
    let startValue = 0;
    let increment = targetValue > 1000 ? 100 : (targetValue > 100 ? 1 : 0.1);
    let stepTime = Math.abs(Math.floor(duration / (targetValue / increment)));
    
    let currentValue = startValue;
    
    const timer = setInterval(function() {
        currentValue += increment;
        
        if (currentValue >= targetValue) {
            clearInterval(timer);
            currentValue = targetValue;
        }
        
        // Format the displayed value
        if (isPercentage) {
            element.textContent = currentValue.toFixed(1);
        } else if (targetValue >= 1000) {
            element.textContent = Math.round(currentValue).toLocaleString();
        } else {
            element.textContent = currentValue.toFixed(0);
        }
        
    }, stepTime);
}
</script>

<style>
.mockup-container {
    max-width: 360px;
    width: 100%;
    position: relative;
    margin: 0 auto;
}

.post-mockup {
    background-color: #222222;
    border-radius: 12px;
    box-shadow: var(--shadow);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 16px;
    display: flex;
    gap: 12px;
    position: relative;
    z-index: 1;
}

.post-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
}

.post-content {
    flex: 1;
}

.post-author {
    font-weight: 600;
    font-size: 14px;
    color: var(--color-white);
    margin-bottom: 2px;
}

.post-meta {
    font-size: 12px;
    color: var(--color-text-light);
    margin-bottom: 12px;
}

.post-text p {
    margin-bottom: 8px;
    color: var(--color-white);
    font-size: 14px;
    line-height: 1.4;
}

.post-text p:last-child {
    margin-bottom: 0;
}

.testing-indicator {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: rgba(0, 0, 0, 0.9);
    border-radius: 12px;
    z-index: 2;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
}

.testing-indicator.active {
    opacity: 1;
}

.testing-pulse {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.8);
    margin-bottom: 12px;
    animation: testing-pulse-animation 1.5s infinite;
}

@keyframes testing-pulse-animation {
    0% {
        transform: scale(0.8);
        opacity: 0.8;
    }
    50% {
        transform: scale(1);
        opacity: 1;
    }
    100% {
        transform: scale(0.8);
        opacity: 0.8;
    }
}

.testing-indicator p {
    color: var(--color-white);
    font-size: 14px;
    margin: 0;
}


.results-panel {
    background-color: #222222;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    box-shadow: var(--shadow);
    padding: 16px;
    margin-top: 12px;
    transform: translateY(20px);
    opacity: 0;
    transition: transform 0.5s ease, opacity 0.5s ease;
}

.results-panel.active {
    transform: translateY(0);
    opacity: 1;
}

.results-header {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-white);
    margin-bottom: 16px;
}

.metrics-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.metric {
    display: flex;
    align-items: center;
    gap: 10px;
}

.metric-name {
    width: 80px;
    font-size: 13px;
    color: var(--color-text-light);
    flex-shrink: 0;
}

.metric-bar-container {
    flex: 1;
    height: 6px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    overflow: hidden;
}

.metric-bar {
    height: 100%;
    width: 0;
    background-color: var(--color-white);
    border-radius: 3px;
    transition: width 1.5s ease-out;
}

#reach-bar {
    background-color: rgba(255, 255, 255, 0.8);
}

#engagement-bar {
    background-color: rgba(255, 255, 255, 0.8);
}

.sentiment-section {
    height: 100%;
    width: 0;
    transition: width 0.5s ease-out;
    float: left;
}

.sentiment-section.negative {
    background-color: rgba(255, 255, 255, 0.3);
}

.sentiment-section.neutral {
    background-color: rgba(255, 255, 255, 0.5);
}

.sentiment-section.positive {
    background-color: rgba(255, 255, 255, 0.8);
}

.metric-value {
    width: 80px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-white);
    text-align: right;
    flex-shrink: 0;
}


.mockup-container.step-testing .testing-indicator {
    opacity: 1;
}

.mockup-container.step-results .results-panel {
    transform: translateY(0);
    opacity: 1;
}

@media (max-width: 992px) {
    .mockup-container {
        margin-top: 30px;
    }
}

@media (max-width: 768px) {
    .mockup-container {
        max-width: 320px;
    }
}


@keyframes fillMeter {
    0% { width: 0%; }
    100% { width: 100%; }
}

@keyframes countUp {
    0% { content: "0"; }
    20% { content: "2000"; }
    40% { content: "4000"; }
    60% { content: "6000"; }
    80% { content: "8000"; }
    100% { content: "10000"; }
}

@keyframes engagementCount {
    0% { content: "0%"; }
    20% { content: "12%"; }
    40% { content: "25%"; }
    60% { content: "49%"; }
    80% { content: "67%"; }
    100% { content: "84%"; }
}

.loaded .meter-bar {
    animation: fillMeter 3s forwards;
    width: 100%;
}

