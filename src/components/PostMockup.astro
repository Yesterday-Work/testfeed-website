    background-color: var(--color-white);
    border-radius: 3px;
}

.metric-value {
    width: 40px;
    font-size: 0.85rem;
    text-align: right;
    color: var(--color-white);
}

.sentiment-meter {
    flex: 1;
    display: flex;
    gap: 3px;
}

.sentiment-negative,
.sentiment-neutral,
.sentiment-positive {
    flex: 1;
    height: 6px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
}

.sentiment-negative.active {
    background-color: #FF6B6B;
}

.sentiment-neutral.active {
    background-color: #FFBB33;
}

.sentiment-positive.active {
    background-color: #26C485;
}

.comments-preview {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
}

.comments-preview h4 {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-white);
}

.comment {
    background-color: rgba(0, 0, 0, 0.2);
    border-radius: var(--border-radius-sm);
    padding: var(--spacing-sm);
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.comment p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-light);
}

--- END OLD/UNUSED STYLES --- */
</style>
