---
import { problemSectionSchema } from '../content/config';
import type { z } from 'astro:content';
import { Icon } from 'astro-icon/components';

// Define props type using the schema
export type Props = z.infer<typeof problemSectionSchema>;

// Destructure props
const { title, cards } = Astro.props;
---

<section class="problem">
  <div class="container">
    <h2 set:html={title}></h2> 
    <div class="problem-grid">
      {cards.map(card => (
        <div class="problem-card">
          <div class="problem-icon">
            <Icon name={`lucide:${card.icon}`} />
          </div>
          <h3>{card.title}</h3> 
          <p>{card.text}</p> 
        </div>
      ))}
    </div>
  </div>
</section> 

<style>
.problem {
    background-color: #151515;
}

.problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
}

.problem-card {
    background-color: var(--color-card-bg);
    padding: var(--spacing-lg);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow);
    transition: var(--transition);
    height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.problem-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.problem-icon {
    margin-bottom: var(--spacing-md);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-highlight);
}

.problem-icon :global(svg) {
    width: 30px;
    height: 30px;
}
</style> 
