---
interface AuthorBioData {
  role?: string;
  credentials?: string;
  linkedinUrl?: string;
  headshotUrl?: string;
  authorPageUrl?: string;
}

interface Props {
  author: string;
  authorBio?: AuthorBioData;
}

const { author, authorBio } = Astro.props;
---

<div class="author-bio" itemscope itemtype="https://schema.org/Person">
  {authorBio?.headshotUrl ? (
    <img
      class="author-headshot"
      src={authorBio.headshotUrl}
      alt={`${author} headshot`}
      width="64"
      height="64"
      loading="lazy"
      decoding="async"
      itemprop="image"
    />
  ) : (
    <div class="author-headshot author-placeholder" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#756c60" stroke-width="1.5" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
    </div>
  )}
  <div class="author-details">
    <p class="author-byline-label">Written by</p>
    {authorBio?.authorPageUrl ? (
      <a href={authorBio.authorPageUrl} class="author-name" itemprop="name">{author}</a>
    ) : (
      <span class="author-name" itemprop="name">{author}</span>
    )}
    {authorBio?.role && <p class="author-role" itemprop="jobTitle">{authorBio.role}</p>}
    {authorBio?.credentials && <p class="author-credentials" itemprop="description">{authorBio.credentials}</p>}
    {authorBio?.linkedinUrl && (
      <a
        href={authorBio.linkedinUrl}
        class="author-linkedin"
        target="_blank"
        rel="noopener noreferrer"
        itemprop="sameAs"
        aria-label={`${author} on LinkedIn`}
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        View on LinkedIn
      </a>
    )}
  </div>
</div>

<style>
  .author-bio {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: #f0ebe0;
    border-radius: 8px;
    margin-top: 2.5rem;
    border: 1px solid rgba(36, 31, 25, 0.1);
  }
  .author-headshot {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid rgba(36, 31, 25, 0.12);
  }
  .author-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(36, 31, 25, 0.07);
    border: 2px solid rgba(36, 31, 25, 0.12);
  }
  .author-details {
    flex: 1;
    min-width: 0;
  }
  .author-byline-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #756c60;
    margin: 0 0 0.2rem 0;
    font-weight: 600;
  }
  .author-name {
    display: block;
    font-weight: 700;
    font-size: 1rem;
    color: #241f19;
    text-decoration: none;
    margin-bottom: 0.2rem;
    line-height: 1.3;
  }
  a.author-name:hover {
    text-decoration: underline;
  }
  .author-role {
    font-size: 0.85rem;
    color: #756c60;
    margin: 0 0 0.3rem 0;
    font-weight: 500;
  }
  .author-credentials {
    font-size: 0.85rem;
    color: #3d3730;
    margin: 0 0 0.75rem 0;
    line-height: 1.5;
  }
  .author-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: #0a66c2;
    text-decoration: none;
    font-weight: 500;
  }
  .author-linkedin:hover {
    text-decoration: underline;
  }

  @media (max-width: 580px) {
    .author-bio {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
