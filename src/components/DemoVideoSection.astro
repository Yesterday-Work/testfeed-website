---
import { videoSectionSchema } from '../content/config';
import type { z } from 'astro:content';

// Define props type
export type Props = z.infer<typeof videoSectionSchema>;

const { title, videoId } = Astro.props;
const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;
---

<section id="demo" class="demo-video">
  <div class="container">
    <h2 set:html={title}></h2> 
    <div class="video-container" id={`youtube-player-${videoId}`}>
      <div class="video-placeholder" role="button" tabindex="0" aria-label="Play video">
        <img src={thumbnailUrl} alt="Video thumbnail for {title}" loading="lazy" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; border-radius: var(--border-radius-lg);"/>
        <div class="play-button">
          <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M8 5V19L19 12L8 5Z"/></svg>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ videoId }}>
  document.addEventListener('DOMContentLoaded', () => {
    const videoContainer = document.getElementById(`youtube-player-${videoId}`);
    if (!videoContainer) return;

    const placeholder = videoContainer.querySelector('.video-placeholder');
    if (!placeholder) return;

    placeholder.addEventListener('click', loadVideo);
    placeholder.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        loadVideo();
      }
    });

    function loadVideo() {
      placeholder.removeEventListener('click', loadVideo);
      placeholder.removeEventListener('keydown', loadVideo);
      
      const iframe = document.createElement('iframe');
      iframe.setAttribute('width', '100%');
      iframe.setAttribute('height', '500'); // Or inherit from container
      iframe.setAttribute('src', `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`);
      iframe.setAttribute('title', 'testfeed Demo Video');
      iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
      iframe.setAttribute('allowfullscreen', '');
      iframe.style.borderRadius = 'var(--border-radius-lg)';
      iframe.style.display = 'block';

      videoContainer.innerHTML = ''; // Clear placeholder
      videoContainer.appendChild(iframe);
    }
  });
</script>

<style>
.demo-video {
    padding: var(--spacing-xxl) 0;
}

.video-container {
    position: relative;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transition: var(--transition);
}

.video-container:hover {
    transform: scale(1.01);
    box-shadow: var(--shadow-lg), var(--glow);
}

.video-container iframe {
    display: block;
    border-radius: var(--border-radius-lg);
}

@media (max-width: 992px) {
    .video-container iframe {
        height: 400px;
    }
}

@media (max-width: 768px) {
    .video-container iframe {
        height: 350px;
    }
}

@media (max-width: 480px) {
    .video-container iframe {
        height: 250px;
    }
}

/* Video placeholder styles */
.video-placeholder {
    background-color: rgba(0, 0, 0, 0.8);
    border-radius: var(--border-radius-lg);
    aspect-ratio: 16 / 9;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: var(--shadow-lg);
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
}

.video-placeholder::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 1;
}

.video-placeholder .play-button,
.video-placeholder p {
    position: relative;
    z-index: 2;
}

.video-placeholder:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-lg), var(--glow);
}

.play-button {
    background-color: var(--color-primary);
    color: var(--color-secondary);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
    box-shadow: var(--glow);
}

.play-icon {
    width: 30px;
    height: 30px;
    color: var(--color-secondary);
}
</style> 
