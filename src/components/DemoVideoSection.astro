---
import { videoSectionSchema } from '../content/config';
import type { z } from 'astro:content';

// Define props type
export type Props = z.infer<typeof videoSectionSchema>;

const { title, videoId } = Astro.props;
---

<section id="demo" class="demo-video">
  <div class="container">
    <h2 set:html={title}></h2> 
    <div class="video-container">
      <iframe 
        width="100%" 
        height="500" 
        src={`https://www.youtube.com/embed/${videoId}`} 
        title="testfeed Demo Video" 
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
        allowfullscreen></iframe>
    </div>
  </div>
</section> 

<style>
.demo-video {
    padding: var(--spacing-xxl) 0;
}

.video-container {
    position: relative;
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    transition: var(--transition);
}

.video-container:hover {
    transform: scale(1.01);
    box-shadow: var(--shadow-lg), var(--glow);
}

.video-container iframe {
    display: block;
    border-radius: var(--border-radius-lg);
}

@media (max-width: 992px) {
    .video-container iframe {
        height: 400px;
    }
}

@media (max-width: 768px) {
    .video-container iframe {
        height: 350px;
    }
}

@media (max-width: 480px) {
    .video-container iframe {
        height: 250px;
    }
}

/* Video placeholder styles */
.video-placeholder {
    background-color: rgba(0, 0, 0, 0.8);
    border-radius: var(--border-radius-lg);
    height: 500px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: var(--shadow-lg);
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
}

.video-placeholder::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 1;
}

.video-placeholder .play-button,
.video-placeholder p {
    position: relative;
    z-index: 2;
}

.video-placeholder:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-lg), var(--glow);
}

.play-button {
    background-color: var(--color-primary);
    color: var(--color-secondary);
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
    box-shadow: var(--glow);
}

.play-icon {
    width: 30px;
    height: 30px;
    color: var(--color-secondary);
}
</style> 
