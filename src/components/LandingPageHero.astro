---
import type { landingPageHeroSchema } from '../content/config';
import { z } from 'astro:content';

// Define the props based on the Zod schema
type Props = z.infer<typeof landingPageHeroSchema>;

const { 
    title,
    description,
    imageUrl,
    imageAlt,
    cta1Text,
    cta1Link,
    cta2Text,
    cta2Link 
} = Astro.props;
---

<section class="hero-section">
    <div class="container">
        <div class="hero-content">
            <div class="text-container">
                <h1 set:html={title}></h1>
                <p>{description}</p>
                
                {(cta1Text && cta1Link) || (cta2Text && cta2Link) ? (
                    <div class="button-group">
                        {cta1Text && cta1Link && (
                            <a href={cta1Link} class="btn btn-primary btn-large pulse">{cta1Text}</a>
                        )}
                        {cta2Text && cta2Link && (
                            <a href={cta2Link} class="btn btn-secondary btn-large">{cta2Text}</a>
                        )}
                    </div>
                ) : null}
            </div>

            {imageUrl && (
                <div class="image-container">
                    <img 
                        src={imageUrl} 
                        alt={imageAlt || 'Hero image'} 
                        class="hero-image" 
                        loading="eager" 
                        decoding="async"
                    />
                </div>
            )}
        </div>
    </div>
</section> 

<style>
.hero-section {
    background-color: var(--color-background); 
    padding: var(--spacing-xl) 0; 
    text-align: center; 
}

.hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
}

.text-container h1 {
    margin-bottom: var(--spacing-sm);

}

.text-container p {
    color: var(--color-text-light);
    max-width: 600px; 
    margin-left: auto;
    margin-right: auto;
    margin-bottom: var(--spacing-md);
}

.button-group {
    display: flex;
    flex-wrap: wrap; 
    justify-content: center;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
}

.image-container {
    margin-top: var(--spacing-lg);
    max-width: 800px;
    width: 100%;
}

.hero-image {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius-lg); 
    box-shadow: var(--shadow-lg);
    object-fit: cover; 
}

@media (min-width: 768px) {
    .hero-content {
        flex-direction: row; 
        text-align: left;
        gap: var(--spacing-xl);
    }

    .text-container {
        flex: 1; 
    }

    .text-container p {
        margin-left: 0;
        margin-right: 0;
    }

    .button-group {
        justify-content: flex-start;
    }

    .image-container {
        flex: 1; 
        margin-top: 0;
        max-width: 50%; 
    }
}

@media (min-width: 992px) {
    .hero-section {
        padding: var(--spacing-xxl) 0;
    }
} 
</style> 
