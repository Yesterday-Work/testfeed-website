---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

{items && items.length > 0 && (
  <div class="key-takeaways" role="note" aria-label="Key takeaways">
    <p class="takeaways-label">Key Takeaways</p>
    <ul class="takeaways-list">
      {items.map(item => <li>{item}</li>)}
    </ul>
  </div>
)}

<style>
  .key-takeaways {
    background: #f0ebe0;
    border-left: 4px solid #241f19;
    border-radius: 0 6px 6px 0;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
  }
  .takeaways-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #756c60;
    margin: 0 0 0.75rem 0;
  }
  .takeaways-list {
    margin: 0;
    padding-left: 1.25rem;
    color: #241f19;
  }
  .takeaways-list li {
    margin-bottom: 0.4rem;
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .takeaways-list li:last-child {
    margin-bottom: 0;
  }
</style>
