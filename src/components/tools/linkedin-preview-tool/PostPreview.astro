---
import PostHeader from './preview-parts/PostHeader.astro';
import PostBody from './preview-parts/PostBody.astro';
import PostStats from './preview-parts/PostStats.astro';
import PostActions from './preview-parts/PostActions.astro';

export interface Props {
  profileName?: string;
  profileHeadline?: string;
  postTime?: string;
  postText?: string;
  profileImageUrl?: string;
  postImageUrl?: string;
  likeCount?: number;
  commentCount?: number;
  repostCount?: number;
  showFirstLiker?: boolean;
  firstLikerName?: string;
}

const {
  profileName = "Millie Marconi", 
  profileHeadline = "Founder of testfeed | Creating better content through audience simulation",
  postTime = "1d", 
  postText = "Imagine knowing exactly how your LinkedIn post will perform BEFORE you hit publish.\n\ntestfeed creates a simulated audience that shows exactly how people will respond to your LinkedIn posts.\n\nNo more guessing which version works better or if your message will resonate. See potential issues and audience preferences BEFORE posting.\n\nStop publishing content without knowing how it will perform.",
  profileImageUrl = "",
  postImageUrl = "", 
  likeCount = 87,
  commentCount = 24,
  repostCount = 12,
  showFirstLiker = true,
  firstLikerName = "Millie's Mum"
} = Astro.props;
---

<div class="linkedin-post-preview">
  <PostHeader 
    profileName={profileName} 
    profileHeadline={profileHeadline} 
    postTime={postTime} 
    profileImageUrl={profileImageUrl} 
  />
  <PostBody 
    postText={postText} 
    postImageUrl={postImageUrl}
  />
  <PostStats 
    likeCount={likeCount}
    commentCount={commentCount}
    repostCount={repostCount}
    showFirstLiker={showFirstLiker}
    firstLikerName={firstLikerName}
  />
  <PostActions />
</div>

<style>
  .linkedin-post-preview {
    background-color: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08);
    width: 100%;
    max-width: 552px;
    margin: 20px auto;
    padding: 12px 16px 8px 16px;
    font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    font-size: 14px;
    line-height: 1.4;
    overflow: hidden;
    box-sizing: border-box;
  }
  
  .linkedin-post-preview :global(.post-text p) {
    color: #000000 !important;
  }
  
  /* Start reducing margins at larger screens */
  @media (max-width: 768px) {
    .linkedin-post-preview {
      max-width: 100%;
      margin: 10px auto;
    }
  }
  
  /* Medium screens - start adjusting font sizes */
  @media (max-width: 600px) {
    .linkedin-post-preview {
      padding: 12px 14px 8px 14px;
    }
    
    .linkedin-post-preview :global(.post-stats) {
      font-size: 12px !important; 
    }
  }
  
  /* Small screens - more aggressive adjustments */
  @media (max-width: 500px) {
    .linkedin-post-preview {
      padding: 10px 12px 6px 12px;
      font-size: 12px;
      border-radius: 6px;
    }
    
    /* Remove the font-size override from parent to allow child components to set their own size */
    .linkedin-post-preview :global(.post-stats) {
      font-size: 10px !important;
    }
    
    .linkedin-post-preview :global(.reactions-text),
    .linkedin-post-preview :global(.comments-reposts),
    .linkedin-post-preview :global(.comment-count),
    .linkedin-post-preview :global(.repost-count) {
      font-size: 10px !important;
    }
  }
</style> 
