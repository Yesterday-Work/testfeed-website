---
export interface Props {
  postText: string;
  postImageUrl?: string;
  hasReadMore?: boolean;
}

const { 
  postText, 
  postImageUrl, 
  hasReadMore = false  // Keeping the prop but we won't actually use it
} = Astro.props;

// Process the post text to properly handle line breaks
// LinkedIn treats consecutive \n as a single break, not as multiple paragraph breaks
const formattedText = postText
  .replace(/\n\s*\n/g, '\n\n') // Normalize multiple line breaks to exactly two
  .split('\n\n')               // Split by paragraph (double line breaks)
  .map((paragraph) => paragraph.trim());
---

<div class="post-body">
  <div class="post-text">
    {formattedText.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </div>
  
  {postImageUrl && (
    <div class="post-media">
      <img src={postImageUrl} alt="Post image" class="post-image" />
    </div>
  )}
</div>

<style>
  .post-body {
    width: 100%;
    margin-bottom: 8px;
    padding: 0;
    position: relative;
  }

  .post-text {
    margin-bottom: 8px;
    width: 100%;
    padding: 0;
  }

  .post-text p {
    margin: 0 0 16px 0;
    padding: 0;
    font-size: 14px;
    line-height: 1.4;
    color: #000000;
    word-wrap: break-word;
    white-space: pre-wrap;
    text-align: left;
    width: 100%;
    text-indent: 0;
    display: block;
    box-sizing: border-box;
    overflow-wrap: break-word;
    font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  .post-text p:last-child {
    margin-bottom: 0;
  }

  .post-media {
    margin-top: 8px;
    margin-left: -16px;
    margin-right: -16px;
    width: calc(100% + 32px);
    font-size: 0; 
    line-height: 0;
    display: block;
    overflow: hidden;
    background-color: #f3f2f0;
    border-radius: 0;
  }

  .post-media img {
    width: 100%;
    display: block;
    height: auto;
    margin: 0;
    padding: 0;
    border: none;
    object-fit: cover;
    border-radius: 0;
  }

  @media (max-width: 500px) {
    .post-text p {
      font-size: 12px;
      line-height: 1.35;
      margin: 0 0 12px 0;
    }
    
    .post-text p:last-child {
      margin-bottom: 0;
    }
    
    .post-media {
      margin-top: 6px;
    }
  }
</style> 
