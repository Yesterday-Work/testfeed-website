---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="social-share">
  <p class="share-label">Share this article</p>
  <div class="share-buttons">
    <a
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
      class="share-btn share-linkedin"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on LinkedIn"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      LinkedIn
    </a>

    <a
      href={`https://x.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
      class="share-btn share-x"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on X (Twitter)"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.734-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      Share on X
    </a>

    <button
      class="share-btn share-copy"
      data-url={url}
      aria-label="Copy link to clipboard"
      type="button"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="14" height="14" x="8" y="8" rx="2"/>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
      </svg>
      <span class="copy-label">Copy Link</span>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const url = btn.dataset.url ?? '';
      const label = btn.querySelector<HTMLElement>('.copy-label');
      navigator.clipboard.writeText(url).then(() => {
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = 'Copy Link'; }, 2000);
        }
      }).catch(() => {});
    });
  });
</script>

<style>
  .social-share {
    margin: 2rem 0;
    padding: 1.25rem 0;
    border-top: 1px solid rgba(36, 31, 25, 0.12);
    border-bottom: 1px solid rgba(36, 31, 25, 0.12);
  }
  .share-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #756c60;
    margin: 0 0 0.75rem 0;
    font-weight: 600;
  }
  .share-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.875rem;
    border-radius: 5px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
    line-height: 1;
    font-family: inherit;
  }
  .share-btn:hover {
    opacity: 0.82;
    transform: translateY(-1px);
  }
  .share-linkedin {
    background: #0a66c2;
    color: #fff;
  }
  .share-x {
    background: #000;
    color: #fff;
  }
  .share-copy {
    background: rgba(36, 31, 25, 0.07);
    color: #241f19;
    border: 1px solid rgba(36, 31, 25, 0.18);
  }
</style>
