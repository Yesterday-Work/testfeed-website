---
import type { z } from 'astro:content';
import { finalCtaSectionSchema } from '../content/config';

// Define props type
export type Props = z.infer<typeof finalCtaSectionSchema>;

const { title, text, buttonText, buttonLink, buttonType = 'primary' } = Astro.props;
---

<section id="get-started" class="final-cta">
  <div class="container">
    <div class="cta-card">
      <h2 set:html={title}></h2>
      <p set:html={text}></p>
      <a href={buttonLink} class={`btn btn-${buttonType} btn-large pulse`}>{buttonText}</a>
    </div>
  </div>
</section> 

<style>
.final-cta {
    padding: var(--spacing-xxl) 0;
    background-color: #111111;
}

.cta-card {
    background-color: var(--color-card-bg);
    border-radius: var(--border-radius-lg);
    padding: var(--spacing-xl) var(--spacing-lg);
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    box-shadow: var(--shadow-lg);
    border: 1px solid rgba(255, 255, 255, 0.3);
}

.cta-card h2 {
    color: var(--color-white);
    margin-bottom: var(--spacing-md);
}

.cta-card p {
    color: var(--color-text-light);
    font-size: 1.2rem;
    margin-bottom: var(--spacing-lg);
}

.waitlist-form {
    display: flex;
    max-width: 600px;
    margin: 0 auto;
    gap: var(--spacing-sm);
}

.waitlist-form input {
    flex: 1;
    padding: 15px;
    border-radius: var(--border-radius);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.05);
    color: var(--color-white);
    font-size: 1rem;
}

.waitlist-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.3);
}

.waitlist-form button {
    padding: 15px 30px;
} 
</style> 
