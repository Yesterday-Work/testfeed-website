---
---

<section class="news">
  <div class="news-wrap">
    <div class="news-band">
      <div class="nb-copy">
        <h2>Get the next one in your inbox.</h2>
        <p>Sharp, practical writing on audience research and decision-making. No spin, no spam.</p>
      </div>
      <form class="news-form" id="blogNewsForm" novalidate>
        <div class="field" id="newsField">
          <input type="email" placeholder="Enter your email" aria-label="Email address" required />
          <button type="submit" class="sub-btn">
            Subscribe
            <span class="arr">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </button>
        </div>
        <p class="news-msg" id="blogNewsMsg"></p>
        <p class="hint">Join 4,000+ operators. Unsubscribe any time.</p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('blogNewsForm') as HTMLFormElement | null;
  if (form) {
    const input = form.querySelector('input') as HTMLInputElement;
    const msg = document.getElementById('blogNewsMsg') as HTMLParagraphElement;
    const field = document.getElementById('newsField') as HTMLDivElement;
    const hint = form.querySelector<HTMLParagraphElement>('.hint');

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const val = input.value.trim();
      const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
      if (!valid) {
        msg.className = 'news-msg err show';
        msg.textContent = 'Please enter a valid email address.';
        input.focus();
        return;
      }
      if (hint) hint.style.display = 'none';
      field.style.display = 'none';
      msg.className = 'news-msg ok show';
      msg.textContent = "Thanks — you're on the list.";
    });
  }
</script>

<style>
  .news { background: #F8F5F1; }
  .news-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 40px;
  }
  .news-band {
    background: #F1EDE7;
    border: 1px solid rgba(0,0,0,0.10);
    border-radius: 12px;
    padding: 44px 48px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 36px;
  }
  .nb-copy h2 {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 30px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #111;
    margin: 0 0 8px;
  }
  .nb-copy p {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.5;
    color: #5F5F5F;
    margin: 0;
    max-width: 420px;
  }
  .news-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 360px;
  }
  .field {
    display: flex;
    background: #F8F5F1;
    border: 1px solid rgba(0,0,0,0.10);
    border-radius: 999px;
    overflow: hidden;
    padding: 4px;
  }
  .field input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    color: #111;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    padding: 10px 16px;
  }
  .field input::placeholder { color: #B5B5B5; }
  .sub-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Playfair Display', serif;
    font-weight: 500;
    font-size: 14px;
    padding: 9px 12px 9px 18px;
    border-radius: 999px;
    background: #111;
    color: #fff;
    border: 0;
    cursor: pointer;
    white-space: nowrap;
    transition: background 160ms;
  }
  .sub-btn:hover { background: #222; }
  .sub-btn:active { transform: translateY(1px); }
  .arr {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: rgba(255,255,255,0.18);
    display: inline-grid;
    place-items: center;
  }
  .news-msg {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    line-height: 1.4;
    display: none;
    padding-left: 6px;
  }
  .news-msg.show { display: block; }
  .news-msg.ok { color: #1E7A3C; }
  .news-msg.err { color: #E6392E; }
  .hint {
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    color: #5F5F5F;
    padding-left: 6px;
    margin: 0;
  }

  @media (max-width: 1000px) {
    .news-band { grid-template-columns: 1fr; gap: 24px; }
    .news-form { min-width: 0; }
  }
  @media (max-width: 600px) {
    .news-wrap { padding: 40px 20px; }
    .news-band { padding: 30px 24px; }
  }
</style>
