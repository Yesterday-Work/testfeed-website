---
// Brand footer — matches the editorial dark footer on the landing page
// (src/pages/index.astro). Self-contained: hardcodes the brand colours/fonts
// and uses inline SVGs (no lucide dependency), so it works site-wide through
// BaseLayout and Layout.
const bookingUrl = "https://app.usemotion.com/meet/millie-marconi/meeting";
const year = new Date().getFullYear();
---

<footer class="brand-footer">
  <div class="bf-wrap">
    <div class="bf-grid">
      <div class="bf-brand">
        <a class="bf-fm" href="/" aria-label="testfeed home">
          <img src="/assets/logo-primary.png" alt="testfeed" />
          <span class="bf-logodot"></span>
        </a>
        <p>Your AI panel. Ready when you are.</p>
        <div class="bf-social">
          <a href="https://www.linkedin.com/company/testfeed-ai/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
        </div>
      </div>

      <nav class="bf-col bf-nav" aria-label="Footer">
        <a href="/#platform">Product</a>
        <a href="/tools/">Tools</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
        <a href={bookingUrl} target="_blank" rel="noopener">Contact</a>
        <a href="/privacy-policy/">Privacy</a>
        <a href="/terms-of-service/">Terms</a>
      </nav>

      <div class="bf-signup">
        <h4>Sign up for our updates</h4>
        <form class="bf-field" id="bf-signup-form" novalidate>
          <input type="email" placeholder="Enter your email" aria-label="Email address" required />
          <button type="submit" aria-label="Subscribe">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </form>
        <p class="bf-signup-msg" id="bf-signup-msg" hidden></p>
      </div>
    </div>

    <div class="bf-bottom">
      <span class="bf-cp">© {year} TestFeed</span>
      <span class="bf-made">Made by <a href="https://yesterday.work" target="_blank" rel="noopener">yesterday</a></span>
    </div>
  </div>
</footer>

<script is:inline>
  (function () {
    var form = document.getElementById("bf-signup-form");
    if (!form) return;
    var wrap = form.closest(".bf-signup");
    var input = form.querySelector("input");
    var msg = document.getElementById("bf-signup-msg");
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var val = (input.value || "").trim();
      var valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
      msg.hidden = false;
      if (!valid) {
        msg.className = "bf-signup-msg err";
        msg.textContent = "Please enter a valid email address.";
        input.focus();
        return;
      }
      wrap.classList.add("done");
      msg.className = "bf-signup-msg ok";
      msg.textContent = "Thanks — you're on the list. We'll be in touch.";
    });
  })();
</script>

<style>
  .brand-footer {
    background: #161616;
    color: rgba(255, 255, 255, 0.7);
    font-family: "Inter", sans-serif;
  }
  .bf-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 44px 40px 26px;
  }
  .bf-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1.2fr;
    gap: 28px;
  }

  .bf-fm {
    display: inline-flex;
    align-items: flex-end;
    margin-bottom: 16px;
    text-decoration: none;
  }
  .bf-fm img {
    height: 20px;
    width: auto;
    display: block;
    filter: invert(1);
  }
  .bf-logodot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #e6392e;
    display: inline-block;
    margin: 0 0 3px 3px;
    flex: 0 0 auto;
  }
  .bf-brand p {
    font-size: 13.5px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 18px;
    max-width: 180px;
  }
  .bf-social {
    display: flex;
    gap: 10px;
  }
  .bf-social a {
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    display: grid;
    place-items: center;
    color: #fff;
    border: 0;
    transition: background 160ms ease;
  }
  .bf-social a svg {
    width: 14px;
    height: 14px;
  }
  .bf-social a:hover {
    background: #e6392e;
  }

  .bf-nav {
    display: flex;
    flex-direction: column;
    padding-top: 2px;
  }
  .bf-col a {
    display: block;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    border: 0;
    margin-bottom: 11px;
    transition: color 160ms ease;
  }
  .bf-col a:hover {
    color: #fff;
  }

  .bf-signup h4 {
    font-family: "Inter", sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: #fff;
    margin: 0 0 16px;
  }
  .bf-field {
    display: flex;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
  }
  .bf-field input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    color: #fff;
    font: inherit;
    font-size: 13px;
    padding: 10px 12px;
  }
  .bf-field input::placeholder {
    color: rgba(255, 255, 255, 0.45);
  }
  .bf-field button {
    background: transparent;
    border: 0;
    color: #e6392e;
    padding: 0 12px;
    cursor: pointer;
    display: grid;
    place-items: center;
  }
  .bf-field button svg {
    width: 16px;
    height: 16px;
  }
  .bf-signup-msg {
    margin: 12px 0 0;
    font-size: 12.5px;
    line-height: 1.4;
  }
  .bf-signup-msg.ok {
    color: #fff;
  }
  .bf-signup-msg.err {
    color: #e6392e;
  }
  .bf-signup.done .bf-field {
    display: none;
  }

  .bf-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 36px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .bf-cp,
  .bf-made {
    font-size: 11.5px;
    color: rgba(255, 255, 255, 0.4);
    white-space: nowrap;
  }
  .bf-made a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: underline;
  }
  .bf-made a:hover {
    color: #fff;
  }

  @media (max-width: 860px) {
    .bf-wrap {
      padding: 36px 20px 24px;
    }
    .bf-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .bf-bottom {
      flex-direction: column;
      gap: 8px;
      justify-content: center;
      text-align: center;
    }
  }
</style>
