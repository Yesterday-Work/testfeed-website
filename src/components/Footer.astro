<footer class="site-footer">
  <div class="ft-wrap">

    <div class="foot-grid">

      <!-- Brand col -->
      <div class="foot-brand">
        <a class="ft-mark" href="/">
          <img src="/assets/logo-primary.png" alt="testfeed" width="88" height="20" />
          <span class="logodot" aria-hidden="true"></span>
        </a>
        <p>Your AI panel. Ready when you are.</p>
        <div class="foot-social">
          <a href="https://www.linkedin.com/company/testfeed-ai/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav col -->
      <div class="foot-col">
        <a href="/">Product</a>
        <a href="/blog/">Blog</a>
        <a href="/about/">About</a>
        <a href="/privacy-policy/">Privacy</a>
      </div>

      <!-- CTA col -->
      <div class="foot-col">
        <h4>Stop guessing.</h4>
        <a href="https://app.usemotion.com/meet/millie-marconi/meeting" target="_blank" rel="noopener">Book a demo</a>
        <a href="https://yesterday.work" target="_blank" rel="noopener">Made by Yesterday</a>
      </div>

    </div>

    <div class="foot-bottom">
      <span class="cp">&copy; 2026 TestFeed</span>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: #161616;
    color: rgba(255,255,255,0.7);
    font-family: 'Inter', sans-serif;
  }
  .ft-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 44px 40px 26px;
  }

  /* ── Grid ────────────────────────────────────────────────── */
  .foot-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1.2fr;
    gap: 28px;
    margin-bottom: 36px;
  }

  /* ── Brand col ───────────────────────────────────────────── */
  .ft-mark {
    display: inline-flex;
    align-items: flex-end;
    gap: 0;
    text-decoration: none;
    border: 0;
    margin-bottom: 16px;
  }
  .ft-mark img {
    height: 20px;
    width: auto;
    display: block;
    filter: invert(1);
  }
  .logodot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #E6392E;
    display: inline-block;
    margin: 0 0 2px 3px;
    flex-shrink: 0;
  }
  .foot-brand p {
    font-size: 13.5px;
    line-height: 1.4;
    color: rgba(255,255,255,0.55);
    margin: 0 0 18px;
    max-width: 180px;
  }
  .foot-social {
    display: flex;
    gap: 10px;
  }
  .foot-social a {
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: rgba(255,255,255,0.08);
    display: grid;
    place-items: center;
    color: #fff;
    border: 0;
    text-decoration: none;
    transition: background 160ms;
  }
  .foot-social a:hover { background: #E6392E; }

  /* ── Nav / CTA cols ──────────────────────────────────────── */
  .foot-col {
    display: flex;
    flex-direction: column;
    gap: 11px;
    padding-top: 2px;
  }
  .foot-col h4 {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: #fff;
    margin: 0 0 5px;
  }
  .foot-col a {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    border: 0;
    transition: color 160ms;
  }
  .foot-col a:hover { color: #fff; }

  /* ── Bottom bar ──────────────────────────────────────────── */
  .foot-bottom {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.10);
  }
  .cp {
    font-size: 11.5px;
    color: rgba(255,255,255,0.4);
    white-space: nowrap;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .foot-grid { grid-template-columns: 1fr 1fr; }
    .foot-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .ft-wrap { padding: 36px 20px 22px; }
    .foot-grid { grid-template-columns: 1fr 1fr; gap: 20px; }
    .foot-brand { grid-column: 1 / -1; }
  }
</style>
