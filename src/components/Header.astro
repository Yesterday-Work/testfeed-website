---
const bookingUrl = "https://app.usemotion.com/meet/millie-marconi/meeting";
---

<header class="site-header" id="siteHeader">
  <div class="wrap">
    <a class="wordmark" href="/">
      <img src="/assets/logo-primary.png" alt="testfeed" />
      <span class="logodot"></span>
    </a>
    <nav class="nav" id="nav">
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a class="btn nav-cta" href={bookingUrl} target="_blank" rel="noopener">
        Book a demo
        <span class="arr">
          <svg viewBox="0 0 13 13"><line x1="2" y1="6.5" x2="11" y2="6.5"/><polyline points="7,2.5 11,6.5 7,10.5"/></svg>
        </span>
      </a>
    </nav>
    <a class="btn header-btn" href={bookingUrl} target="_blank" rel="noopener">
      Book a demo
      <span class="arr">
        <svg viewBox="0 0 13 13"><line x1="2" y1="6.5" x2="11" y2="6.5"/><polyline points="7,2.5 11,6.5 7,10.5"/></svg>
      </span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</header>

<script is:inline>
  (function(){
    var header = document.getElementById('siteHeader');
    var toggle = document.getElementById('navToggle');
    if (!toggle) return;
    toggle.addEventListener('click', function(){
      var open = header.classList.toggle('open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.innerHTML = open
        ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/></svg>'
        : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
    });

    document.querySelectorAll('a[href^="#"]').forEach(function(a){
      a.addEventListener('click', function(e){
        var href = this.getAttribute('href');
        if (href === '#') return;
        var target = document.querySelector(href);
        if (target) { e.preventDefault(); window.scrollTo({ top: target.offsetTop - 72, behavior: 'smooth' }); }
      });
    });
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-1);
    border-bottom: 1px solid var(--border-1, rgba(0,0,0,0.10));
  }
  .site-header .wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .wordmark {
    display: inline-flex;
    align-items: flex-end;
    gap: 0;
    text-decoration: none;
    border: 0;
    flex-shrink: 0;
  }
  .wordmark img { height: 20px; width: auto; display: block; }
  .logodot {
    width: 5px; height: 5px; border-radius: 999px;
    background: var(--tf-red); display: inline-block;
    margin: 0 0 3px 3px; flex: 0 0 auto;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 32px;
    margin: 0 auto;
  }
  .nav a:not(.btn) {
    font-family: var(--font-body);
    font-weight: var(--w-medium);
    font-size: 15px;
    color: var(--tf-ink);
    text-decoration: none;
    border: 0;
    white-space: nowrap;
  }
  .nav a:not(.btn):hover { color: var(--tf-red); }
  .nav a.nav-cta { display: none; }

  .header-btn { flex-shrink: 0; }

  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--tf-black);
    padding: 6px;
    margin-left: auto;
    align-items: center;
    justify-content: center;
  }
  .nav-toggle svg { width: 24px; height: 24px; }

  /* Mobile */
  @media (max-width: 768px) {
    .site-header .wrap { padding: 0 20px; }
    .nav {
      position: absolute;
      top: 100%; left: 0; right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--bg-1);
      border-top: 1px solid var(--border-1, rgba(0,0,0,0.10));
      padding: 6px 0 12px;
      display: none;
      z-index: 60;
      box-shadow: 0 24px 40px rgba(0,0,0,0.08);
    }
    .site-header.open .nav { display: flex; }
    .nav a:not(.btn) { padding: 14px 20px; font-size: 16px; border-bottom: 1px solid var(--border-1, rgba(0,0,0,0.08)); }
    .nav a.nav-cta { display: inline-flex; margin: 12px 20px 0; }
    .header-btn { display: none; }
    .nav-toggle { display: inline-flex; }
  }
</style>
