---
import { Icon } from "astro-icon/components";
---

<header class="site-header">
    <div class="header-container">
        <nav>
            <a href="/" class="logo"
                ><span class="testfeed-font">testfeed</span></a
            >
            <div class="nav-links">
                <a href="/about/">About</a>
                <a href="#get-started" class="btn-join">Join Beta</a>
            </div>
            <div class="mobile-nav">
                <a href="#get-started" class="btn-join mobile-cta"
                    >Join Beta</a
                >
                <!-- Hamburger menu commented out - only one link (About) not worth the menu
                <button class="hamburger" aria-label="Toggle menu">
                  <span></span>
                  <span></span>
                  <span></span>
                </button>
                --></span>
            </div>
        </nav>
    </div>

    <!-- Mobile Menu Overlay Background - Commented out for now
    <div class="mobile-menu-overlay-bg"></div>

    <div class="mobile-menu-dropdown">
        <div class="mobile-menu-content">
            <a href="/about/">About</a>
        </div>
    </div>
    -->
</header>

<script is:inline>
    // @ts-nocheck
    // Header component JavaScript
    document.addEventListener("DOMContentLoaded", function () {
        setupSmoothScrolling();
    });

    // Smooth scrolling for anchor links
    function setupSmoothScrolling() {
        document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
            anchor.addEventListener("click", function (e) {
                e.preventDefault();

                const href = this.getAttribute("href");
                if (href === "#") return;

                const targetElement = document.querySelector(href);
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80, // Offset for header
                        behavior: "smooth",
                    });
                }
            });
        });
    }

    // Mobile menu functionality
    const hamburger = document.querySelector(".hamburger");
    const mobileMenuDropdown = document.querySelector(".mobile-menu-dropdown");
    const mobileMenuOverlayBg = document.querySelector(
        ".mobile-menu-overlay-bg",
    );

    if (hamburger) {
        hamburger.addEventListener("click", () => {
            hamburger.classList.toggle("active");
            mobileMenuDropdown.classList.toggle("active");
            mobileMenuOverlayBg.classList.toggle("active");
        });
    }

    // Close menu when clicking overlay
    if (mobileMenuOverlayBg) {
        mobileMenuOverlayBg.addEventListener("click", () => {
            hamburger.classList.remove("active");
            mobileMenuDropdown.classList.remove("active");
            mobileMenuOverlayBg.classList.remove("active");
        });
    }

    // Close menu when clicking a link
    document.querySelectorAll(".mobile-menu-content a").forEach((link) => {
        link.addEventListener("click", () => {
            hamburger.classList.remove("active");
            mobileMenuDropdown.classList.remove("active");
            mobileMenuOverlayBg.classList.remove("active");
        });
    });
</script>

<style>
    /* Header Component Styles */

    .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        padding: 1rem 2rem 0 2rem;
    }

    .site-header > .header-container {
        position: relative;
        z-index: 100;
        background: rgba(17, 17, 17, 0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .header-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 60px;
    }

    .logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--color-white);
        letter-spacing: -0.5px;
    }

    .logo:hover {
        opacity: 0.9;
    }

    .nav-links {
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .nav-links a {
        color: rgba(255, 255, 255, 0.7);
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.2s ease;
        font-family: "Poppins", sans-serif;
    }

    .nav-links a:hover {
        color: var(--color-white);
    }

    .btn-join {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 0.5rem 1rem;
        border-radius: 6px;
        color: var(--color-white) !important;
        font-family: "Poppins", sans-serif;
        font-weight: 500 !important;
        font-size: 0.875rem !important;
        letter-spacing: 0;
        text-transform: none;
        transition: all 0.2s ease;
    }

    .btn-join:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    /* Mobile Navigation */
    .mobile-nav {
        display: none;
        gap: 1rem;
        align-items: center;
    }

    .hamburger {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        width: 24px;
        height: 20px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
    }

    .hamburger span {
        display: block;
        width: 100%;
        height: 2px;
        background: var(--color-white);
        transition: all 0.3s ease;
        transform-origin: center;
    }

    .hamburger.active span:nth-child(1) {
        transform: translateY(9px) rotate(45deg);
    }

    .hamburger.active span:nth-child(2) {
        opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
        transform: translateY(-9px) rotate(-45deg);
    }

    /* Mobile Menu Overlay Background */
    .mobile-menu-overlay-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0, 0, 0, 0.7);
        z-index: 90;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.3s ease,
            visibility 0.3s ease;
    }

    .mobile-menu-overlay-bg.active {
        opacity: 1;
        visibility: visible;
    }

    /* Mobile Menu Dropdown */
    .mobile-menu-dropdown {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 2rem;
        right: 2rem;
        background: rgba(17, 17, 17, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
        z-index: 95;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .mobile-menu-dropdown.active {
        max-height: 500px;
    }

    .mobile-menu-content {
        display: flex;
        flex-direction: column;
        padding: 2rem;
    }

    .mobile-menu-content a {
        font-size: 1rem;
        font-weight: 400;
        color: var(--color-white);
        text-decoration: none;
        padding: 0.75rem 0;
        transition: opacity 0.2s ease;
    }

    .mobile-menu-content a:hover {
        opacity: 0.7;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .site-header {
            padding: 0.75rem 1rem 0 1rem;
        }

        .header-container {
            padding: 0 1.5rem;
        }

        .nav-links {
            display: none;
        }

        .mobile-nav {
            display: flex;
        }

        .mobile-menu-dropdown {
            left: 1rem;
            right: 1rem;
        }

        .mobile-menu-content {
            padding: 1.5rem;
        }
    }
</style>
