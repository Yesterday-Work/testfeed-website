---
import { Icon } from "astro-icon/components";
---
<header class="site-header">
  <div class="header-container">
    <nav>
      <a href="/" class="logo"><span class="testfeed-font">testfeed</span></a>
      <div class="nav-links">
        <a href="/about/">About</a>
        <a href="/#get-started" class="btn-join">JOIN WAITLIST</a>
      </div>
      <div class="mobile-nav">
        <a href="/#get-started" class="btn-join mobile-cta">JOIN WAITLIST</a>
        <button class="hamburger" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>
  </div>
  
  <!-- Mobile Menu Overlay Background -->
  <div class="mobile-menu-overlay-bg"></div>
  
  <!-- Mobile Menu Dropdown -->
  <div class="mobile-menu-dropdown">
    <div class="mobile-menu-content">
      <a href="/about/">About</a>
    </div>
  </div>
</header>

<script is:inline>
// @ts-nocheck
// Header component JavaScript
document.addEventListener('DOMContentLoaded', function() {
    setupSmoothScrolling();
});

// Smooth scrolling for anchor links
function setupSmoothScrolling() {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            
            const href = this.getAttribute('href');
            if (href === '#') return;
            
            const targetElement = document.querySelector(href);
            if (targetElement) {
                window.scrollTo({
                    top: targetElement.offsetTop - 80, // Offset for header
                    behavior: 'smooth'
                });
            }
        });
    });
}

// Mobile menu functionality
const hamburger = document.querySelector('.hamburger');
const mobileMenuDropdown = document.querySelector('.mobile-menu-dropdown');
const mobileMenuOverlayBg = document.querySelector('.mobile-menu-overlay-bg');

if (hamburger) {
    hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mobileMenuDropdown.classList.toggle('active');
        mobileMenuOverlayBg.classList.toggle('active');
    });
}

// Close menu when clicking overlay
if (mobileMenuOverlayBg) {
    mobileMenuOverlayBg.addEventListener('click', () => {
        hamburger.classList.remove('active');
        mobileMenuDropdown.classList.remove('active');
        mobileMenuOverlayBg.classList.remove('active');
    });
}

// Close menu when clicking a link
document.querySelectorAll('.mobile-menu-content a').forEach(link => {
    link.addEventListener('click', () => {
        hamburger.classList.remove('active');
        mobileMenuDropdown.classList.remove('active');
        mobileMenuOverlayBg.classList.remove('active');
    });
});
</script>

<style>
/* Header Component Styles */

.site-header {
    background: var(--color-background);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.site-header > .header-container {
    position: relative;
    z-index: 100;
}

.header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
}

nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px;
}

.logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white);
    letter-spacing: -0.5px;
}

.logo:hover {
    opacity: 0.9;
}

.nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
}

.nav-links a {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
    font-family: 'Space Mono', monospace;
}

.nav-links a:hover {
    color: var(--color-white);
}

.btn-join {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    color: var(--color-white) !important;
    font-family: 'Space Mono', monospace;
    font-weight: 400 !important;
    font-size: 0.75rem !important;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: all 0.2s ease;
}

.btn-join:hover {
    background: rgba(255, 255, 255, 0.08);
}

/* Mobile Navigation */
.mobile-nav {
    display: none;
    gap: 1rem;
    align-items: center;
}

.hamburger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 24px;
    height: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
}

.hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-white);
    transition: all 0.3s ease;
    transform-origin: center;
}

.hamburger.active span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
}

.hamburger.active span:nth-child(2) {
    opacity: 0;
}

.hamburger.active span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
}

/* Mobile Menu Overlay Background */
.mobile-menu-overlay-bg {
    position: fixed;
    top: 60px;
    left: 0;
    width: 100%;
    height: calc(100vh - 60px);
    background: rgba(0, 0, 0, 0.7);
    z-index: 90;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
}

.mobile-menu-overlay-bg.active {
    opacity: 1;
    visibility: visible;
}

/* Mobile Menu Dropdown */
.mobile-menu-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: var(--color-background);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    z-index: 95;
}

.mobile-menu-dropdown.active {
    max-height: 500px;
}

.mobile-menu-content {
    display: flex;
    flex-direction: column;
    padding: 2rem;
}

.mobile-menu-content a {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-white);
    text-decoration: none;
    padding: 0.75rem 0;
    transition: opacity 0.2s ease;
}

.mobile-menu-content a:hover {
    opacity: 0.7;
}

/* Responsive */
@media (max-width: 768px) {
    .nav-links {
        display: none;
    }
    
    .mobile-nav {
        display: flex;
    }
}

 
</style>
