---
const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/') && href !== '/';
---

<header class="site-header" id="siteHeader">
  <div class="hdr-wrap">

    <!-- Wordmark -->
    <a class="wordmark" href="/">
      <img src="/assets/logo-primary.png" alt="testfeed" width="96" height="22" />
      <span class="logodot" aria-hidden="true"></span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav" id="nav" aria-label="Main navigation">
      <a href="/" class={isActive('/') && pathname === '/' ? 'active' : ''}>Product</a>
      <a href="/blog/" class={isActive('/blog') ? 'active' : ''}>Blog</a>
      <a href="/about/" class={isActive('/about') ? 'active' : ''}>About</a>
      <a
        class="btn nav-cta"
        href="https://app.usemotion.com/meet/millie-marconi/meeting"
        target="_blank"
        rel="noopener"
      >
        Book a demo
        <span class="arr" aria-hidden="true">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </a>
    </nav>

    <!-- Desktop CTA -->
    <a
      class="btn header-btn"
      href="https://app.usemotion.com/meet/millie-marconi/meeting"
      target="_blank"
      rel="noopener"
    >
      Book a demo
      <span class="arr" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </span>
    </a>

    <!-- Hamburger -->
    <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
      <svg class="icon-menu" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <svg class="icon-close" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

  </div>
</header>

<script>
  const header  = document.getElementById('siteHeader')!;
  const toggle  = document.getElementById('navToggle')!;
  const iconMenu  = toggle.querySelector('.icon-menu') as HTMLElement;
  const iconClose = toggle.querySelector('.icon-close') as HTMLElement;

  // Sticky border
  window.addEventListener('scroll', () => {
    header.classList.toggle('stuck', window.scrollY > 8);
  }, { passive: true });

  // Hamburger
  toggle.addEventListener('click', () => {
    const open = header.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    iconMenu.style.display  = open ? 'none'  : '';
    iconClose.style.display = open ? ''      : 'none';
  });
</script>

<style>
  /* ── Design tokens ───────────────────────────────────────── */
  :root {
    --tf-black:  #111111;
    --tf-red:    #E6392E;
    --tf-stone:  #5F5F5F;
    --tf-fog:    #B5B5B5;
    --tf-cream:  #F8F5F1;
    --tf-line:   rgba(0,0,0,0.10);
  }

  /* ── Header shell ────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 80;
    background: rgba(248,245,241,0.90);
    backdrop-filter: saturate(1.2) blur(10px);
    -webkit-backdrop-filter: saturate(1.2) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color 240ms cubic-bezier(0.22,1,0.36,1);
  }
  .site-header.stuck { border-bottom-color: var(--tf-line); }

  .hdr-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    height: 68px;
    display: flex;
    align-items: center;
    gap: 28px;
  }

  /* ── Wordmark ────────────────────────────────────────────── */
  .wordmark {
    display: inline-flex;
    align-items: flex-end;
    gap: 0;
    text-decoration: none;
    border: 0;
    flex-shrink: 0;
  }
  .wordmark img { height: 22px; width: auto; display: block; }
  .logodot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--tf-red);
    display: inline-block;
    margin: 0 0 3px 3px;
    flex-shrink: 0;
  }

  /* ── Desktop nav ─────────────────────────────────────────── */
  .nav {
    display: flex;
    gap: 32px;
    align-items: center;
    margin: 0 auto;
  }
  .nav a:not(.btn) {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 15px;
    color: var(--tf-black);
    text-decoration: none;
    border: 0;
    white-space: nowrap;
    transition: color 160ms;
  }
  .nav a:not(.btn):hover,
  .nav a.active { color: var(--tf-red); }
  .nav a.nav-cta { display: none; }

  /* ── CTA button ──────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: 'Playfair Display', serif;
    font-weight: 500;
    font-size: 15px;
    padding: 10px 10px 10px 20px;
    border-radius: 999px;
    background: var(--tf-black);
    color: #fff;
    border: 0;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: background 160ms;
    flex-shrink: 0;
  }
  .btn:hover { background: #222; color: #fff; }
  .arr {
    width: 26px;
    height: 26px;
    border-radius: 999px;
    background: rgba(255,255,255,0.18);
    display: inline-grid;
    place-items: center;
    flex-shrink: 0;
  }

  /* ── Hamburger ───────────────────────────────────────────── */
  .nav-toggle {
    display: none;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--tf-black);
    padding: 6px;
    margin-left: auto;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1000px) {
    /* Mobile nav dropdown */
    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--tf-cream);
      border-top: 1px solid var(--tf-line);
      padding: 6px 0 12px;
      margin: 0;
      display: none;
      z-index: 60;
      box-shadow: 0 24px 40px rgba(0,0,0,0.10);
    }
    .site-header.open .nav { display: flex; }

    .nav a:not(.btn) {
      padding: 14px 40px;
      font-size: 16px;
      border-bottom: 1px solid var(--tf-line);
    }
    .nav a:not(.btn):last-of-type { border-bottom: 0; }

    /* Show CTA in mobile dropdown */
    .nav a.nav-cta {
      display: inline-flex;
      margin: 12px 40px 0;
      align-self: flex-start;
    }

    /* Hide desktop CTA, show hamburger */
    .header-btn { display: none; }
    .nav-toggle  { display: inline-grid; }
  }

  @media (max-width: 600px) {
    .hdr-wrap { padding: 0 20px; height: 60px; }
    .nav a:not(.btn) { padding-left: 20px; padding-right: 20px; }
    .nav a.nav-cta   { margin-left: 20px; margin-right: 20px; }
  }
</style>
