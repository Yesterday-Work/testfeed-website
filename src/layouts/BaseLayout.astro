---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro'; 

export interface Props {
	// From the content file's frontmatter
	title?: string;        // From pageTitle in content
	description?: string;  // From pageDescription in content
	entry?: any;           // The full content entry object
	customMeta?: Array<{name: string, content: string}>; // Custom meta tags
}

// IMPORTANT: This is a fallback as a safety net,
// best practice is to always include title and description 
// in every content file 
const { 
	title = 'TestFeed - AI Audiences', 
	description = 'Create virtual AI audiences that think and act like your real customers, mentors, consultants, and stakeholders. It\'s like having them sitting next to you while you work.',
	entry = null,
	customMeta = []
} = Astro.props;

// Determine robots content - default to index, follow
let robotsContent = "index, follow";
const customRobotsMeta = customMeta.find(meta => meta.name && meta.name.toLowerCase() === 'robots');
if (customRobotsMeta) {
  robotsContent = customRobotsMeta.content;
}

// Get the site URL for absolute paths
const siteUrl = Astro.url.origin; // Gets https://testfeed.ai

// Set up Open Graph and Twitter card images - ALWAYS use absolute URLs for social sharing
let ogImage = new URL('/assets/og-image.jpg', siteUrl).href;
let twitterImage = new URL('/assets/twitter-image.jpg', siteUrl).href;

// Use featured image from page content if available
if (entry?.data?.featuredImage) {
  if (entry.data.featuredImage.startsWith('/')) {
    // Convert relative URLs to absolute
    ogImage = new URL(entry.data.featuredImage, siteUrl).href;
    twitterImage = ogImage;
  } else if (entry.data.featuredImage.startsWith('http')) {
    // Already an absolute URL
    ogImage = entry.data.featuredImage;
    twitterImage = entry.data.featuredImage;
  }
}

// Get image alt text if available
const imageAlt = entry?.data?.imageAlt || entry?.data?.featuredImageAlt || title;

// Determine content type
const isArticle = entry?.data?.schemaMarkup?.type === 'BlogPosting' || 
                 entry?.data?.publishDate != null;
const contentType = isArticle ? 'article' : 'website';

const schemaData = entry?.data?.schemaMarkup 
	? {
			"@context": "https://schema.org",
			"@type": entry.data.schemaMarkup.type,
			"name": title,
			"description": description,
			"url": Astro.url.href,
			...(entry.data.schemaMarkup.properties || {})
		}
	: {
			"@context": "https://schema.org",
			"@type": "WebPage",
			"name": title,
			"description": description,
			"url": Astro.url.href
		};

// Add image to schema if available
if (ogImage) {
  schemaData.image = ogImage;
}
---
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
	<title>{title}</title>
	<meta name="description" content={description}>

	{/* Custom Meta Tags */}
	{customMeta.filter(meta => meta.name && meta.name.toLowerCase() !== 'robots').map(meta => (
		<meta name={meta.name} content={meta.content} />
	))}

	<meta name="robots" content={robotsContent} />
	<link rel="canonical" href={Astro.url.href} />

	{/* Open Graph Tags - used by Facebook, LinkedIn, etc. */}
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={Astro.url.href} />
	<meta property="og:image" content={ogImage} />
	<meta property="og:image:alt" content={imageAlt} />
	<meta property="og:type" content={contentType} />
	<meta property="og:site_name" content="TestFeed" />
	
	{/* Twitter Card Tags */}
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={title} />
	<meta name="twitter:description" content={description} />
	<meta name="twitter:image" content={twitterImage} />
	<meta name="twitter:image:alt" content={imageAlt} />
	<meta name="twitter:site" content="@testfeed" />

	{/* Schema.org JSON-LD structured data */}
	<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

	{/* Design system + brand tokens */}
	<link rel="stylesheet" href="/assets/ds.css" />

	{/* SEO Performance Suggestions */}
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

	{/* Space Mono (code/mono) + Tiny5 (logo) still needed */}
	<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Tiny5&display=swap" rel="stylesheet">

	{/* Favicons */}
	<link rel="icon" href="/favicon.svg" type="image/svg+xml">
	<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
	<link rel="manifest" href="/site.webmanifest">
</head>
<body>
	<Header />
	
	<!-- The main content from each page will be injected here -->
	<slot />

	<Footer />

	<!-- Global scripts -->
	<script src="/src/scripts/script.js"></script>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--tf-ink);
    background: var(--bg-1);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--tf-ink);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  h1 { font-size: clamp(2rem, 5vw, 3.5rem); }
  h2 { font-size: clamp(1.6rem, 3.5vw, 2.5rem); text-align: left; }
  h3 { font-size: 1.4rem; }
  p  { color: var(--tf-stone); margin-bottom: 1rem; }
  a  { color: var(--tf-red); text-decoration: none; transition: color 0.2s; }
  a:hover { color: #b32820; }
  ul { list-style: disc; }
  ol { list-style: decimal; }
  section { padding: 80px 0; }
  img { display: block; max-width: 100%; }

  /* Shared button */
  .btn {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--font-body); font-weight: var(--w-semibold);
    font-size: 15px; padding: 11px 12px 11px 22px;
    border-radius: 999px; background: var(--tf-black);
    color: #fff; border: 0; cursor: pointer;
    text-decoration: none; transition: background 0.2s;
  }
  .btn:hover { background: #222; color: #fff; }
  .btn .arr {
    width: 26px; height: 26px; border-radius: 999px;
    background: rgba(255,255,255,0.18);
    display: inline-grid; place-items: center;
  }
  .btn .arr svg { width: 13px; height: 13px; stroke: currentColor; stroke-width: 2.2; fill: none; }
  .btn-primary { background: var(--tf-red); }
  .btn-primary:hover { background: #b32820; }

  /* Scroll animation */
  .animate-on-scroll { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .animate-on-scroll.show { opacity: 1; transform: translateY(0); }

  /* Logo font */
  .testfeed-font { font-family: 'Tiny5', monospace; font-size: 120%; display: inline-block; vertical-align: middle; }
</style>
